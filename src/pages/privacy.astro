---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTABand from "../components/sections/CTABand.astro";
---

<BaseLayout
  title="Privacy Policy | Unify Social"
  description="Unify's Privacy Policy — how we collect, use, and protect your data."
  bodyBg="#171616"
>
  <main>

    <!-- ── Hero ── -->
    <section class="pv-hero">
      <img src="/assets/blobs/blob-3.svg" class="pv-blob" alt="" aria-hidden="true" loading="eager" />
      <div class="pv-hero-inner">
        <span class="pv-eyebrow">Legal</span>
        <h1 class="pv-headline">Privacy Policy<span class="pv-period">.</span></h1>
        <p class="pv-updated">Last updated: January 6, 2026</p>
      </div>
    </section>

    <!-- ── Content ── -->
    <section class="pv-content" id="pv-content">
      <div class="pv-doc">

        <div class="pv-section">
          <h2 class="pv-section-title">General</h2>
          <p class="pv-p">Unify is a digital platform designed to support newcomers through accessible resources and community connection. Protecting your privacy is important to us. This Privacy Policy explains what information we collect, how we use it, and the rights you have regarding your data.</p>
          <p class="pv-p">By creating an account or using Unify, you agree to the terms outlined below.</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">Information We Collect</h2>
          <p class="pv-p">We only collect the minimum information needed to create and maintain your account: email address. This is collected when you sign up using google sign-in or creating an account directly.</p>
          <p class="pv-p">We do not collect your name, phone number, address, demographic information, financial information, or any additional personal data.</p>
          <p class="pv-p">We do not track your activity across other websites or apps.</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">How We Use Your Information</h2>
          <p class="pv-p">We use your email address to:</p>
          <ul class="pv-list">
            <li>Create and authenticate your Unify account</li>
            <li>Allow you to log in securely</li>
            <li>Send essential service related messages (ex. Password reset, critical updates)</li>
            <li>Maintain platform security and functionality</li>
          </ul>
          <p class="pv-p">We do not use your email for marketing without your explicit consent</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">How We Protect Your Information</h2>
          <p class="pv-p">We use industry standard security measures to safeguard your data, including:</p>
          <ul class="pv-list">
            <li>Encrypted connections (HTTPS)</li>
            <li>Secure authentication methods</li>
            <li>Limited internal access</li>
            <li>Use of reputable authentication services</li>
          </ul>
          <p class="pv-p">We do not store your Google password or access your Google profile data beyond your email</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">Sharing of Information</h2>
          <p class="pv-p">We do not sell, rent, or trade your personal information.</p>
          <p class="pv-p">We only disclose your email if required in the following situations:</p>
          <ul class="pv-list">
            <li>To comply with legal obligations (ex. Court order)</li>
            <li>To investigate or address potential security risks or misuse</li>
            <li>To provide core functionality through trusted service providers (ex. Authentication tools)</li>
          </ul>
          <p class="pv-p">Any service providers we use must follow strict privacy and security standards</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">Your Rights &amp; Choices</h2>
          <p class="pv-p">Depending on your location, you may have the right to:</p>
          <ul class="pv-list">
            <li>Access the information we hold about you (your email address)</li>
            <li>Request deletion of your account and data</li>
            <li>Request correction if your email is incorrect</li>
            <li>Withdraw consent by deleting your account</li>
            <li>Lodge a complaint with your local data protection authority</li>
          </ul>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">Data Retention</h2>
          <p class="pv-p">We retain your email address only for as long as your account remains active.</p>
          <p class="pv-p">If you delete your account, we delete your associated data unless we are required by law to retain it for a short period.</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">Children's Privacy</h2>
          <p class="pv-p">Unify is not intended for children under the age of 13 (or the equivalent age of digital consent in your region)</p>
          <p class="pv-p">We do not knowingly collect personal information from children. If we become aware that a child has created an account, we will delete it promptly.</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section">
          <h2 class="pv-section-title">Changes to This Policy</h2>
          <p class="pv-p">We may update this Privacy Policy from time to time. If significant changes are made, we will notify you through email or in-app before the new policy takes effect.</p>
        </div>

        <div class="pv-divider" aria-hidden="true"></div>

        <div class="pv-section pv-section--last">
          <h2 class="pv-section-title">Contact Information</h2>
          <p class="pv-p">If you have questions about this Privacy Policy or would like to exercise your rights, contact us at <a href="mailto:contact@unifysocial.ca" class="pv-link">contact@unifysocial.ca</a></p>
        </div>

      </div>
    </section>

    <CTABand />
  </main>
</BaseLayout>

<style>
  /* ── Hero ── */
  .pv-hero {
    position: relative;
    background-color: var(--color-ink);
    overflow: hidden;
    margin-top: -67px;
    display: flex;
    align-items: flex-end;
    padding: calc(67px + 3.5rem) 2rem 5rem;
  }

  .pv-blob {
    position: absolute;
    top: -10%;
    right: -8%;
    width: clamp(300px, 44vw, 620px);
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
  }

  .pv-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1600px;
    width: 100%;
    margin: 0 auto;
  }

  .pv-eyebrow {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin-bottom: 1rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.1s forwards;
  }

  .pv-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8.5vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: var(--tracking-display);
    color: #fff;
    margin: 0 0 1.75rem;
    opacity: 0;
    animation: hero-fade-up 0.7s var(--ease-out) 0.2s forwards;
  }

  .pv-period {
    color: var(--color-brand-red);
    font-style: italic;
  }

  .pv-updated {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.34s forwards;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Content ── */
  .pv-content {
    background-color: var(--color-cream);
    padding: 5rem 2rem 7rem;
  }

  .pv-doc {
    max-width: 760px;
    margin: 0 auto;
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
  }

  body.js-ready .pv-doc {
    opacity: 0;
    transform: translateY(24px);
  }

  body.js-ready .pv-content.visible .pv-doc {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Sections ── */
  .pv-section {
    padding-bottom: 0;
  }

  .pv-section--last {
    padding-bottom: 0;
  }

  .pv-divider {
    width: 100%;
    height: 1px;
    background: rgba(23, 22, 22, 0.07);
    margin: 2.5rem 0;
  }

  .pv-section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
    border-left: 2px solid var(--color-brand-red);
    padding-left: 0.875rem;
    margin: 0 0 1.25rem;
    line-height: 1.4;
  }

  /* ── Body copy ── */
  .pv-p {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 0.875rem;
  }

  /* ── Lists ── */
  .pv-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.875rem;
  }

  .pv-list li {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.25rem;
  }

  .pv-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-brand-red);
    font-weight: 600;
  }

  /* ── Email link ── */
  .pv-link {
    color: var(--color-brand-red);
    text-decoration: underline;
    text-decoration-color: rgba(216, 74, 41, 0.4);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }

  .pv-link:hover {
    text-decoration-color: var(--color-brand-red);
  }

  /* ── Responsive ── */
  @media (max-width: 479px) {
    .pv-hero {
      padding: calc(67px + 2rem) 1.25rem 4rem;
    }

    .pv-content {
      padding: 4rem 1.25rem 6rem;
    }
  }

  @media (min-width: 810px) {
    .pv-hero {
      padding: calc(67px + 4.5rem) 3rem 6rem;
    }

    .pv-content {
      padding: 5.5rem 3rem 8rem;
    }
  }

  @media (min-width: 1400px) {
    .pv-hero {
      padding: calc(67px + 5rem) 5rem 7rem;
    }

    .pv-content {
      padding: 6rem 5rem 9rem;
    }
  }
</style>

<script>
  const content = document.getElementById("pv-content");
  if (content) {
    document.body.classList.add("js-ready");
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          content.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.05 }
    );
    observer.observe(content);
  }
</script>
