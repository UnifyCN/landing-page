---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import CTABand from "../components/sections/CTABand.astro";
---

<BaseLayout
  title="Terms of Service | Unify Social"
  description="Unify's End User License Agreement & Terms of Service."
  bodyBg="#171616"
>
  <main>

    <!-- ── Hero ── -->
    <section class="ts-hero">
      <img src="/assets/blobs/blob-3.svg" class="ts-blob" alt="" aria-hidden="true" loading="eager" />
      <div class="ts-hero-inner">
        <span class="ts-eyebrow">Legal</span>
        <h1 class="ts-headline">Terms of Service<span class="ts-period">.</span></h1>
        <p class="ts-subtitle">End User License Agreement &amp; Terms of Service</p>
        <p class="ts-updated">Last updated: March 3, 2026</p>
      </div>
    </section>

    <!-- ── Content ── -->
    <section class="ts-content" id="ts-content">
      <div class="ts-doc">

        <!-- 1 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">01</span>
            <span class="ts-title">Agreement to These Terms</span>
          </h2>
          <p class="ts-p">By creating an account or using Unify Social (the "App"), you agree to be bound by this End User License Agreement and Terms of Service (collectively, "Terms"). If you do not agree, you may not use the App.</p>
          <p class="ts-p">These Terms constitute a legally binding agreement between you and Unify Social ("Unify," "we," "us," or "our"). Apple Inc. is not a party to this agreement and has no obligation or liability with respect to the App or these Terms.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 2 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">02</span>
            <span class="ts-title">License to Use the App</span>
          </h2>
          <p class="ts-p">Subject to your compliance with these Terms, Unify grants you a limited, non-exclusive, non-transferable, revocable license to use the App on Apple-branded devices that you own or control, solely for personal, non-commercial purposes.</p>
          <p class="ts-p">You may not:</p>
          <ul class="ts-list">
            <li>Copy, modify, or distribute the App or any part of it</li>
            <li>Reverse engineer, decompile, or attempt to extract the source code</li>
            <li>Rent, lease, loan, sell, or sublicense the App</li>
            <li>Use the App for any unlawful purpose</li>
          </ul>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 3 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">03</span>
            <span class="ts-title">Eligibility</span>
          </h2>
          <p class="ts-p">You must be at least 16 years old to use the App. By agreeing to these Terms, you represent and warrant that you meet this requirement. If you are under 18, you confirm that you have your parent or guardian's permission to use the App.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 4 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">04</span>
            <span class="ts-title">Prohibited Content and Behavior</span>
          </h2>
          <p class="ts-p">Unify Social is a community platform for newcomers to Canada. We have zero tolerance for objectionable content and abusive users. By using the App, you agree not to post, upload, share, or otherwise make available any content that:</p>
          <ul class="ts-list">
            <li>Is hateful, harassing, threatening, or discriminatory based on race, ethnicity, national origin, gender, sexual orientation, religion, disability, immigration status, or any other protected characteristic</li>
            <li>Is sexually explicit, pornographic, or obscene</li>
            <li>Depicts, promotes, or facilitates violence, self-harm, or harm to others</li>
            <li>Exploits, endangers, or sexualizes minors in any way</li>
            <li>Is false, misleading, or designed to deceive other users</li>
            <li>Promotes illegal activities, including fraud, scams, or unauthorized immigration services</li>
            <li>Constitutes spam, unsolicited advertising, or repetitive disruptive posting</li>
            <li>Infringes the intellectual property, privacy, or other rights of any third party</li>
            <li>Contains malware, viruses, or any harmful code</li>
            <li>Impersonates any person, organization, government body, or immigration authority</li>
          </ul>
          <p class="ts-p">You also agree not to engage in abusive behavior toward other users, including but not limited to:</p>
          <ul class="ts-list">
            <li>Harassment, bullying, stalking, or intimidation</li>
            <li>Coordinated attacks or pile-ons targeting a specific user</li>
            <li>Sharing another user's private information without consent (doxxing)</li>
            <li>Attempting to manipulate or exploit newcomers, including predatory financial or housing schemes</li>
          </ul>
          <p class="ts-p">Violations of this section may result in immediate content removal, account suspension, or permanent ban, at our sole discretion.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 5 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">05</span>
            <span class="ts-title">Content Moderation</span>
          </h2>
          <p class="ts-p">We are committed to maintaining a safe and trustworthy community. To that end:</p>
          <ul class="ts-list">
            <li>We review reported content and will respond to objectionable content reports within 24 hours of receiving them</li>
            <li>We reserve the right to remove any content that violates these Terms or our Community Guidelines, without prior notice</li>
            <li>We reserve the right to suspend or permanently ban users who violate these Terms</li>
            <li>Repeat violations or severe single violations may result in immediate permanent account termination</li>
          </ul>
          <p class="ts-p">We may use automated tools, human moderators, or a combination of both to review content. While we make reasonable efforts to moderate the platform, we cannot guarantee that all objectionable content will be identified and removed immediately.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 6 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">06</span>
            <span class="ts-title">Reporting Objectionable Content and Abusive Users</span>
          </h2>
          <p class="ts-p">You have the ability to report content or users that you believe violate these Terms. To report:</p>
          <ul class="ts-list">
            <li>Use the in-app reporting tool available on posts, comments, and user profiles</li>
            <li>Contact us directly at <a href="mailto:contact@unifysocial.ca" class="ts-link">contact@unifysocial.ca</a></li>
          </ul>
          <p class="ts-p">Upon receiving a report, we will review the flagged content and take appropriate action, including removal of content and ejection of the user responsible, within 24 hours where required.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 7 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">07</span>
            <span class="ts-title">User-Generated Content</span>
          </h2>
          <p class="ts-p">You retain ownership of content you post on the App. By posting content, you grant Unify a non-exclusive, royalty-free, worldwide license to use, display, and distribute your content solely for the purpose of operating and improving the App.</p>
          <p class="ts-p">You are solely responsible for the content you post. You represent and warrant that:</p>
          <ul class="ts-list">
            <li>You own or have the right to share the content</li>
            <li>Your content does not violate any applicable law or these Terms</li>
            <li>Your content will not harm or deceive other users, particularly vulnerable newcomers</li>
          </ul>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 8 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">08</span>
            <span class="ts-title">Intellectual Property</span>
          </h2>
          <p class="ts-p">All content, features, and functionality of the App — including but not limited to the Unify name, logo, design, text, and code — are owned by Unify Social and are protected by applicable intellectual property laws. You may not use, reproduce, or distribute any of our proprietary content without our prior written permission.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 9 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">09</span>
            <span class="ts-title">Privacy</span>
          </h2>
          <p class="ts-p">Your use of the App is also governed by our Privacy Policy, available at <a href="mailto:contact@unifysocial.ca" class="ts-link">contact@unifysocial.ca</a>. By using the App, you consent to the data practices described in our Privacy Policy. We collect only your email address to create and maintain your account.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 10 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">10</span>
            <span class="ts-title">Third-Party Services</span>
          </h2>
          <p class="ts-p">The App may contain links to or integrate with third-party services. We are not responsible for the content, privacy practices, or terms of any third-party service. Your use of third-party services is at your own risk and subject to those services' terms.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 11 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">11</span>
            <span class="ts-title">Disclaimers</span>
          </h2>
          <p class="ts-p">The App and all content within it are provided "as is" and "as available" without warranty of any kind, express or implied. Unify does not warrant that:</p>
          <ul class="ts-list">
            <li>The App will be uninterrupted, error-free, or secure</li>
            <li>Any content on the App, including community-generated information, is accurate, complete, or up to date</li>
            <li>The App will meet your specific needs or expectations</li>
          </ul>
          <p class="ts-p">Information shared on the App, including guidance on immigration, housing, or finances, is provided for general informational purposes only and does not constitute professional legal, financial, or immigration advice. Always consult a qualified professional for advice specific to your situation.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 12 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">12</span>
            <span class="ts-title">Limitation of Liability</span>
          </h2>
          <p class="ts-p">To the maximum extent permitted by applicable law, Unify and its team members shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of or inability to use the App, including any harm resulting from reliance on user-generated content.</p>
          <p class="ts-p">Apple has no warranty obligation whatsoever with respect to the App and is not responsible for addressing any claims by you or any third party relating to the App.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 13 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">13</span>
            <span class="ts-title">Termination</span>
          </h2>
          <p class="ts-p">We may suspend or terminate your account at any time, with or without notice, if you violate these Terms or engage in any conduct we determine, in our sole discretion, to be harmful to the community or the App. Upon termination, your license to use the App ends immediately.</p>
          <p class="ts-p">You may delete your account at any time through the App or by contacting us at <a href="mailto:contact@unifysocial.ca" class="ts-link">contact@unifysocial.ca</a>.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 14 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">14</span>
            <span class="ts-title">Changes to These Terms</span>
          </h2>
          <p class="ts-p">We may update these Terms from time to time. We will notify you of material changes via email or an in-app notification before the new Terms take effect. Continued use of the App after the effective date of updated Terms constitutes your acceptance of the changes.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 15 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">15</span>
            <span class="ts-title">Governing Law</span>
          </h2>
          <p class="ts-p">These Terms are governed by the laws of the Province of British Columbia and the federal laws of Canada applicable therein, without regard to conflict of law principles. Any disputes arising from these Terms shall be resolved in the courts of British Columbia, Canada.</p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 16 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">16</span>
            <span class="ts-title">Apple App Store Additional Terms</span>
          </h2>
          <p class="ts-p">The following applies to any version of the App downloaded from the Apple App Store:</p>
          <ul class="ts-list">
            <li>This agreement is between you and Unify Social only, not Apple</li>
            <li>Apple has no obligation to provide maintenance or support for the App</li>
            <li>Apple is not responsible for any product liability claims related to the App</li>
            <li>Apple is not responsible for any claims that the App infringes a third party's intellectual property rights</li>
            <li>Apple has no obligation to address claims relating to the App or your use of it</li>
            <li>You confirm that you are not located in a country subject to a U.S. Government embargo or designated as a "terrorist supporting" country, and that you are not listed on any U.S. Government prohibited or restricted party list</li>
            <li>Apple and its subsidiaries are third-party beneficiaries of this agreement and have the right to enforce it against you</li>
          </ul>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- 17 -->
        <div class="ts-section">
          <h2 class="ts-section-head">
            <span class="ts-num">17</span>
            <span class="ts-title">Contact Us</span>
          </h2>
          <p class="ts-p">If you have questions about these Terms, would like to report a violation, or need to exercise any rights under these Terms, please contact us:</p>
          <p class="ts-p"><strong>Email: <a href="mailto:contact@unifysocial.ca" class="ts-link">contact@unifysocial.ca</a></strong></p>
        </div>

        <div class="ts-divider" aria-hidden="true"></div>

        <!-- Acknowledgement -->
        <div class="ts-section ts-ack">
          <h2 class="ts-ack-title">Acknowledgement</h2>
          <p class="ts-p">By tapping "I Agree" or creating an account, you confirm that you have read, understood, and agree to be bound by these Terms, including the zero-tolerance policy for objectionable content and abusive behaviour.</p>
        </div>

      </div>
    </section>

    <CTABand />
  </main>
</BaseLayout>

<style>
  /* ── Hero ── */
  .ts-hero {
    position: relative;
    background-color: var(--color-ink);
    overflow: hidden;
    margin-top: -67px;
    display: flex;
    align-items: flex-end;
    padding: calc(67px + 3.5rem) 2rem 5rem;
  }

  .ts-blob {
    position: absolute;
    top: -10%;
    right: -8%;
    width: clamp(300px, 44vw, 620px);
    opacity: 0.05;
    pointer-events: none;
    user-select: none;
  }

  .ts-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1600px;
    width: 100%;
    margin: 0 auto;
  }

  .ts-eyebrow {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin-bottom: 1rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.1s forwards;
  }

  .ts-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8.5vw, 7.5rem);
    line-height: 0.9;
    letter-spacing: var(--tracking-display);
    color: #fff;
    margin: 0 0 1.25rem;
    opacity: 0;
    animation: hero-fade-up 0.7s var(--ease-out) 0.2s forwards;
  }

  .ts-period {
    color: var(--color-brand-red);
    font-style: italic;
  }

  .ts-subtitle {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(0.875rem, 1.4vw, 1rem);
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 0.75rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.32s forwards;
  }

  .ts-updated {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.42s forwards;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Content ── */
  .ts-content {
    background-color: var(--color-cream);
    padding: 5rem 2rem 7rem;
  }

  .ts-doc {
    max-width: 760px;
    margin: 0 auto;
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
  }

  body.js-ready .ts-doc {
    opacity: 0;
    transform: translateY(24px);
  }

  body.js-ready .ts-content.visible .ts-doc {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Section headings ── */
  .ts-section {
    padding-bottom: 0;
  }

  .ts-section-head {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0 0 1.25rem;
  }

  .ts-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    line-height: 1;
  }

  .ts-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1rem, 2vw, 1.1875rem);
    color: var(--color-text);
    line-height: 1.3;
  }

  /* ── Dividers ── */
  .ts-divider {
    width: 100%;
    height: 1px;
    background: rgba(23, 22, 22, 0.07);
    margin: 2.5rem 0;
  }

  /* ── Body copy ── */
  .ts-p {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    margin: 0 0 0.875rem;
  }

  .ts-p strong {
    font-weight: 700;
    color: var(--color-text);
  }

  /* ── Lists ── */
  .ts-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.875rem;
  }

  .ts-list li {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.25rem;
  }

  .ts-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--color-brand-red);
    font-weight: 600;
  }

  /* ── Links ── */
  .ts-link {
    color: var(--color-brand-red);
    text-decoration: underline;
    text-decoration-color: rgba(216, 74, 41, 0.4);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.15s ease;
  }

  .ts-link:hover {
    text-decoration-color: var(--color-brand-red);
  }

  /* ── Acknowledgement ── */
  .ts-ack {
    background: rgba(216, 74, 41, 0.05);
    border-left: 3px solid var(--color-brand-red);
    padding: 1.5rem 1.5rem 1.5rem 1.75rem;
    border-radius: 4px;
  }

  .ts-ack-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin: 0 0 0.875rem;
  }

  .ts-ack .ts-p {
    margin-bottom: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 479px) {
    .ts-hero {
      padding: calc(67px + 2rem) 1.25rem 4rem;
    }

    .ts-content {
      padding: 4rem 1.25rem 6rem;
    }
  }

  @media (min-width: 810px) {
    .ts-hero {
      padding: calc(67px + 4.5rem) 3rem 6rem;
    }

    .ts-content {
      padding: 5.5rem 3rem 8rem;
    }
  }

  @media (min-width: 1400px) {
    .ts-hero {
      padding: calc(67px + 5rem) 5rem 7rem;
    }

    .ts-content {
      padding: 6rem 5rem 9rem;
    }
  }
</style>

<script>
  const content = document.getElementById("ts-content");
  if (content) {
    document.body.classList.add("js-ready");
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          content.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.05 }
    );
    observer.observe(content);
  }
</script>
