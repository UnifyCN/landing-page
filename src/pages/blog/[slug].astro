---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostNav from "../../components/blog/PostNav.astro";
import CTABand from "../../components/sections/CTABand.astro";
import { getAllPosts, getPostBySlug, getAllPostSlugs } from "../../lib/sanity/queries";
import { urlFor } from "../../lib/sanity/client";
import { toHTML } from "@portabletext/to-html";
import "../../styles/prose.css";

const toHTMLOptions: any = {
  components: {
    types: {
      table: ({ value }: any) => {
        const rows: any[] = value.rows ?? [];
        if (!rows.length) return '';

        // @sanity/table: cells are plain strings, first row = header
        // @portabletext/markdown (migrated): cells are objects with a .value array
        const isSanityTable = typeof rows[0]?.cells?.[0] === 'string';

        if (isSanityTable) {
          const [headerRow, ...bodyRows] = rows;
          const thead = `<thead><tr>${
            (headerRow.cells as string[]).map((c) => `<th>${c}</th>`).join('')
          }</tr></thead>`;
          const tbody = bodyRows.length
            ? `<tbody>${bodyRows.map((row: any) =>
                `<tr>${(row.cells as string[]).map((c) => `<td>${c}</td>`).join('')}</tr>`
              ).join('')}</tbody>`
            : '';
          return `<table>${thead}${tbody}</table>`;
        }

        const headerCount: number = value.headerRows ?? 0;
        const header = rows.slice(0, headerCount);
        const body = rows.slice(headerCount);

        const renderCells = (cells: any[], tag: 'th' | 'td') =>
          cells.map((cell: any) => `<${tag}>${toHTML(cell.value ?? [], toHTMLOptions)}</${tag}>`).join('');

        const thead = header.length
          ? `<thead><tr>${renderCells(header[0].cells, 'th')}</tr></thead>`
          : '';
        const tbody = body.length
          ? `<tbody>${body.map((row: any) => `<tr>${renderCells(row.cells, 'td')}</tr>`).join('')}</tbody>`
          : '';

        return `<table>${thead}${tbody}</table>`;
      },
    },
  },
};

export async function getStaticPaths() {
  const slugs = await getAllPostSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const [post, allPosts] = await Promise.all([
  getPostBySlug(slug!),
  getAllPosts(),
]);

if (!post) {
  return Astro.redirect("/blog");
}

const postIndex = allPosts.findIndex((p) => p.slug.current === slug);
const prev = postIndex < allPosts.length - 1 ? allPosts[postIndex + 1] : null;
const next = postIndex > 0 ? allPosts[postIndex - 1] : null;

const updatedDate = new Date(post.updatedAt ?? post.publishedAt).toLocaleDateString("en-CA", {
  year: "numeric",
  month: "numeric",
  day: "numeric",
});

const bodyHtml = toHTML(post.body, toHTMLOptions);
---

<BaseLayout
  title={`${post.title} | Unify Social`}
  description={post.description}
  bodyBg="#ffffff"
>
  <main class="post-main">
    <!-- ── Post header ── -->
    <header class="post-header">
      <a href="/blog" class="post-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M11.5 7H2.5M2.5 7L6.5 3M2.5 7L6.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All articles
      </a>
      <h1 class="post-title">{post.title}</h1>
    </header>

    <!-- ── Hero image ── -->
    <div class="post-hero-img-wrap">
      <img
        src={urlFor(post.thumbnail).width(1200).url()}
        alt={post.title}
        class="post-hero-img"
        loading="eager"
      />
    </div>

    <!-- ── Metadata ── -->
    <div class="post-meta">
      <span>Last updated: <strong>{updatedDate}</strong></span>
      {post.craReference && (
        <>
          <span class="post-meta-sep" aria-hidden="true">|</span>
          <span>CRA Reference: <span class="post-meta-ref">{post.craReference}</span></span>
        </>
      )}
    </div>

    <!-- ── Prose body ── -->
    <article class="prose" set:html={bodyHtml} />
  </main>

  <!-- ── Prev / Next ── -->
  <PostNav
    prev={prev ? { title: prev.title, slug: prev.slug.current } : null}
    next={next ? { title: next.title, slug: next.slug.current } : null}
  />

  <CTABand />
</BaseLayout>

<style>
  .post-main {
    max-width: 800px;
    margin: 0 auto;
    padding: calc(67px + 0.75rem) 1.5rem 0;
  }

  /* ── Back link ── */
  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 1.25rem;
    transition: color 0.2s ease;
  }

  .post-back:hover {
    color: var(--color-brand-red);
  }

  /* ── Title ── */
  .post-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.875rem, 5vw, 3.25rem);
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--color-ink);
    margin: 0 0 1.5rem;
  }

  /* ── Hero image ── */
  .post-hero-img-wrap {
    max-width: 1200px;
    margin: 0 auto 0;
    padding: 0 1.5rem;
    width: calc(100% + 3rem);
    margin-left: -1.5rem;
  }

  .post-hero-img {
    width: 100%;
    height: 320px;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }

  /* ── Metadata ── */
  .post-meta {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 1.25rem 0 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .post-meta strong {
    color: var(--color-ink);
    font-weight: 600;
  }

  .post-meta-sep {
    opacity: 0.4;
  }

  .post-meta-ref {
    color: var(--color-brand-red);
  }

  /* ── Prose ── */
  .prose {
    padding-bottom: 3rem;
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .post-main {
      padding: calc(67px + 0.75rem) 3rem 0;
    }

    .post-hero-img-wrap {
      width: calc(100% + 6rem);
      margin-left: -3rem;
      padding: 0 3rem;
    }

    .post-hero-img {
      height: 420px;
      border-radius: 10px;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .post-main {
      padding: calc(67px + 0.75rem) 5rem 0;
      max-width: 900px;
    }

    .post-hero-img-wrap {
      width: calc(100% + 10rem);
      margin-left: -5rem;
      padding: 0 5rem;
    }

    .post-hero-img {
      height: 480px;
    }
  }
</style>
