---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";
import CTABand from "../../components/sections/CTABand.astro";
import { getAllPosts } from "../../lib/sanity/queries";
import { urlFor } from "../../lib/sanity/client";

const posts = await getAllPosts();
const featured = posts[0] ?? null;
const rest = posts.slice(1);

const featuredDate = featured
  ? new Date(featured.publishedAt).toLocaleDateString("en-CA", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<BaseLayout
  title="Unify Social | Make Settling in Canada Simpler, Clearer, and Connected"
  description="Expert tips, guides, and stories to help newcomers navigate life in Canada."
  bodyBg="#171616"
>
  <main>
    <!-- ── Hero ── -->
    <section class="bl-hero">
      <div class="bl-hero-blob" aria-hidden="true">
        <img src="/assets/blobs/blob-3.svg" alt="" />
      </div>
      <div class="bl-hero-inner">
        <p class="bl-hero-eyebrow">Insights &amp; Guides</p>
        <h1 class="bl-hero-headline">The Blog</h1>
        <p class="bl-hero-sub">
          Expert tips, guides, and stories to help you<br class="bl-hero-br" />
          navigate life in Canada.
        </p>
      </div>
    </section>

    <!-- ── Grid ── -->
    <section class="bl-grid-section">
      {posts.length === 0 ? (
        <div class="bl-empty">
          <p>No posts yet — check back soon.</p>
        </div>
      ) : (
        <>
          <!-- Featured post -->
          {featured && (
            <div class="bl-featured-wrap">
              <a href={`/blog/${featured.slug.current}`} class="bl-featured">
                <div class="bl-featured-img-wrap">
                  <img
                    src={urlFor(featured.thumbnail).width(900).url()}
                    alt={featured.title}
                    class="bl-featured-img"
                    loading="eager"
                  />
                </div>
                <div class="bl-featured-body">
                  <p class="bl-featured-eyebrow">Latest</p>
                  <p class="bl-featured-date">{featuredDate}</p>
                  <h2 class="bl-featured-title">{featured.title}</h2>
                  <p class="bl-featured-desc">{featured.description}</p>
                  <span class="bl-featured-cta">
                    Read article
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M2.5 11.5L11.5 2.5M11.5 2.5H5.5M11.5 2.5V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </a>
            </div>
          )}

          <!-- Remaining posts grid -->
          {rest.length > 0 && (
            <div class="blog-grid" id="blog-grid">
              {rest.map((post, i) => (
                <PostCard
                  title={post.title}
                  publishedAt={new Date(post.publishedAt)}
                  thumbnail={urlFor(post.thumbnail).width(600).url()}
                  slug={post.slug.current}
                  index={i}
                />
              ))}
            </div>
          )}
        </>
      )}
    </section>

    <CTABand />
  </main>
</BaseLayout>

<style>
  /* ── Hero ── */
  .bl-hero {
    position: relative;
    overflow: hidden;
    background-color: var(--color-ink);
    margin-top: -67px;
    padding: calc(67px + 5rem) 0 5.5rem;
    display: flex;
    align-items: flex-end;
  }

  .bl-hero-blob {
    position: absolute;
    top: -10%;
    right: -8%;
    width: 44rem;
    pointer-events: none;
    opacity: 0.05;
    transform: rotate(15deg);
  }
  .bl-hero-blob img { width: 100%; height: auto; }

  .bl-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .bl-hero-eyebrow {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin: 0 0 1.25rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.1s forwards;
  }

  .bl-hero-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4rem, 13vw, 10rem);
    line-height: 0.88;
    letter-spacing: var(--tracking-display);
    color: #ffffff;
    margin: 0 0 1.75rem;
    opacity: 0;
    animation: hero-fade-up 0.7s var(--ease-out) 0.18s forwards;
  }

  .bl-hero-sub {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.6vw, 1.1875rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.34s forwards;
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Empty state ── */
  .bl-empty {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-muted);
  }

  /* ── Grid section ── */
  .bl-grid-section {
    background-color: var(--color-cream);
    padding: 5rem 0 6rem;
    position: relative;
    overflow: hidden;
  }

  /* ── Featured ── */
  .bl-featured-wrap {
    max-width: 1200px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  .bl-featured {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    text-decoration: none;
    color: inherit;
  }

  .bl-featured-img-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background-color: rgba(23, 22, 22, 0.06);
  }

  .bl-featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    color: transparent;
    transition: transform 0.5s var(--ease-out);
  }

  .bl-featured:hover .bl-featured-img {
    transform: scale(1.03);
  }

  .bl-featured-eyebrow {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin: 0 0 0.5rem;
  }

  .bl-featured-date {
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .bl-featured-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.375rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0 0 1rem;
    transition: color 0.2s ease;
  }

  .bl-featured:hover .bl-featured-title {
    color: var(--color-brand-red);
  }

  .bl-featured-desc {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-muted);
    margin: 0 0 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bl-featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-brand-red);
    transition: gap 0.2s var(--ease-out);
  }

  .bl-featured:hover .bl-featured-cta {
    gap: 0.625rem;
  }

  /* ── Cards grid ── */
  .blog-grid {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem 2rem;
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .bl-hero-inner {
      padding: 0 3rem;
    }

    .bl-featured-wrap {
      padding: 0 3rem;
      margin-bottom: 4.5rem;
    }

    .bl-featured {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .bl-featured-img-wrap {
      aspect-ratio: unset;
      height: 380px;
    }

    .blog-grid {
      padding: 0 3rem;
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 2rem;
    }

    .bl-hero-br {
      display: none;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .bl-hero-inner {
      padding: 0 5rem;
    }

    .bl-hero {
      padding: calc(67px + 6rem) 0 6.5rem;
    }

    .bl-featured-wrap {
      padding: 0 5rem;
    }

    .bl-featured-img-wrap {
      height: 440px;
    }

    .blog-grid {
      padding: 0 5rem;
      grid-template-columns: repeat(3, 1fr);
      gap: 3.5rem 2.5rem;
    }
  }
</style>

<script>
  const grid = document.getElementById("blog-grid");
  if (grid) {
    grid.classList.add("animate");
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          grid.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.05 }
    );
    observer.observe(grid);
  }
</script>
