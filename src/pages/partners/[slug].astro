---
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import CTABand from "../../components/sections/CTABand.astro";
import { partners, type Partner } from "../../lib/partners";

export async function getStaticPaths() {
  return partners.map((p) => ({ params: { slug: p.slug }, props: { partner: p } }));
}

const { partner } = Astro.props as { partner: Partner };
---

<BaseLayout
  title={`${partner.name} | Unify Social Partners`}
  description={partner.partnershipDescription}
>
  <main class="pp-main">

    <!-- Back -->
    <a href="/partners" class="pp-back">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M11.5 7H2.5M2.5 7L6.5 3M2.5 7L6.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      All partners
    </a>

    <!-- Partner header -->
    <div class="pp-header">
      <div class="pp-logo-wrap">
        <img src={partner.logo} alt={partner.name} class="pp-logo" loading="eager" />
      </div>

      <div class="pp-meta">
        <span class="pp-badge">{partner.category}</span>
        <h1 class="pp-name">{partner.name}</h1>
        <p class="pp-city">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="pp-pin">
            <path d="M6 1C4.067 1 2.5 2.567 2.5 4.5c0 2.625 3.5 6.5 3.5 6.5s3.5-3.875 3.5-6.5C9.5 2.567 7.933 1 6 1zm0 4.75A1.25 1.25 0 1 1 6 3.25a1.25 1.25 0 0 1 0 2.5z" fill="currentColor"/>
          </svg>
          {partner.city}
        </p>
      </div>
    </div>

    <div class="pp-divider" aria-hidden="true"></div>

    <!-- Partnership section -->
    <section class="pp-section" aria-labelledby="pp-partnership-heading">
      <h2 id="pp-partnership-heading" class="pp-section-title">Our partnership with Unify</h2>
      <p class="pp-partnership-text">{partner.partnershipDescription}</p>
    </section>

    <!-- About section -->
    <section class="pp-section" aria-labelledby="pp-about-heading">
      <h2 id="pp-about-heading" class="pp-section-title">About {partner.shortName}</h2>
      <p class="pp-org-text">{partner.orgDescription}</p>
    </section>

    <!-- Visit website CTA -->
    <div class="pp-visit">
      <a
        href={partner.website}
        target="_blank"
        rel="noopener noreferrer"
        class="pp-visit-btn"
      >
        Visit {partner.shortName} website
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7H11.5M11.5 7L7.5 3M11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </main>

  <CTABand />
</BaseLayout>

<style>
  .pp-main {
    max-width: 760px;
    margin: 0 auto;
    padding: calc(67px + 1.5rem) 2rem 0;
  }

  @keyframes pp-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .pp-back {
    opacity: 0;
    animation: pp-fade-up 0.4s var(--ease-out) 0.05s forwards;
  }

  .pp-header {
    opacity: 0;
    animation: pp-fade-up 0.45s var(--ease-out) 0.12s forwards;
  }

  .pp-divider {
    opacity: 0;
    animation: pp-fade-up 0.4s var(--ease-out) 0.2s forwards;
  }

  .pp-section:nth-child(1) {
    opacity: 0;
    animation: pp-fade-up 0.45s var(--ease-out) 0.26s forwards;
  }

  .pp-section:nth-child(2) {
    opacity: 0;
    animation: pp-fade-up 0.45s var(--ease-out) 0.34s forwards;
  }

  .pp-visit {
    opacity: 0;
    animation: pp-fade-up 0.4s var(--ease-out) 0.42s forwards;
  }

  /* Back */
  .pp-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s ease;
  }

  .pp-back:hover {
    color: var(--color-brand-red);
  }

  /* Header */
  .pp-header {
    display: flex;
    align-items: flex-start;
    gap: 1.75rem;
    margin-bottom: 2.5rem;
  }

  .pp-logo-wrap {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(23, 22, 22, 0.1);
    border-radius: 12px;
    padding: 1rem;
    background: #fff;
  }

  .pp-logo {
    max-width: 100%;
    max-height: 60px;
    width: auto;
    object-fit: contain;
  }

  .pp-meta {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-top: 0.25rem;
  }

  .pp-badge {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
  }

  .pp-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.375rem, 3.5vw, 2rem);
    letter-spacing: var(--tracking-tight);
    color: var(--color-ink);
    margin: 0;
    line-height: 1.15;
  }

  .pp-city {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
  }

  .pp-pin {
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* Divider */
  .pp-divider {
    width: 100%;
    height: 1px;
    background: rgba(23, 22, 22, 0.08);
    margin-bottom: 2.5rem;
  }

  /* Sections */
  .pp-section {
    margin-bottom: 2.5rem;
  }

  .pp-section-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8125rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 0.875rem;
  }

  .pp-partnership-text {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.65;
    margin: 0;
  }

  .pp-org-text {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.75;
    margin: 0;
  }

  /* Visit CTA */
  .pp-visit {
    padding: 2.5rem 0 4rem;
  }

  .pp-visit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: #fff;
    background: var(--color-ink);
    text-decoration: none;
    border-radius: 8px;
    padding: 0.875rem 1.75rem;
    transition: background 0.2s ease;
  }

  .pp-visit-btn:hover {
    background: var(--color-brand-red);
  }

  @media (min-width: 810px) {
    .pp-main {
      padding: calc(67px + 1.75rem) 3rem 0;
    }
  }

  @media (min-width: 1400px) {
    .pp-main {
      padding: calc(67px + 2rem) 5rem 0;
      max-width: 860px;
    }
  }
</style>
