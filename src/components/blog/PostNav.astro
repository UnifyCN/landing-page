---
interface NavPost {
  title: string;
  slug: string;
}

interface Props {
  prev: NavPost | null;
  next: NavPost | null;
}

const { prev, next } = Astro.props;
---

<nav class="pn" aria-label="Post navigation">
  <div class="pn-inner">
    {prev ? (
      <a href={`/blog/${prev.slug}`} class="pn-link pn-prev">
        <span class="pn-arrow" aria-hidden="true">←</span>
        <span class="pn-text">
          <span class="pn-label">Previous</span>
          <span class="pn-title">{prev.title}</span>
        </span>
      </a>
    ) : <div />}

    {next ? (
      <a href={`/blog/${next.slug}`} class="pn-link pn-next">
        <span class="pn-text">
          <span class="pn-label">Next</span>
          <span class="pn-title">{next.title}</span>
        </span>
        <span class="pn-arrow" aria-hidden="true">→</span>
      </a>
    ) : <div />}
  </div>
</nav>

<style>
  .pn {
    background-color: var(--color-ink);
    padding: 2.5rem 0;
    margin-top: 4rem;
  }

  .pn-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .pn-link {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s ease;
  }

  .pn-link:hover {
    color: var(--color-brand-red);
  }

  .pn-next {
    justify-content: flex-end;
    text-align: right;
  }

  .pn-arrow {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.1em;
    transition: transform 0.2s var(--ease-out), color 0.2s ease;
    color: var(--color-brand-red);
  }

  .pn-prev:hover .pn-arrow {
    transform: translateX(-4px);
  }

  .pn-next:hover .pn-arrow {
    transform: translateX(4px);
  }

  .pn-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .pn-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
  }

  .pn-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.85);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pn-link:hover .pn-title {
    color: #ffffff;
  }

  @media (max-width: 809px) {
    .pn-inner {
      grid-template-columns: 1fr;
      padding: 0 1.5rem;
    }

    .pn-next {
      justify-content: flex-start;
      text-align: left;
    }
  }

  @media (min-width: 1400px) {
    .pn-inner {
      padding: 0 5rem;
    }
  }
</style>
