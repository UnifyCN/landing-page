---
interface Props {
  title: string;
  publishedAt: Date;
  thumbnail: string;
  slug: string;
  index?: number;
}

const { title, publishedAt, thumbnail, slug, index = 0 } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="pc" style={`--i: ${index}`}>
  <div class="pc-img-wrap">
    <img
      src={thumbnail}
      alt={title}
      class="pc-img"
      loading="lazy"
    />
  </div>
  <div class="pc-body">
    <p class="pc-date">{formattedDate}</p>
    <p class="pc-title">{title}</p>
  </div>
</a>

<style>
  .pc {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out);
    transition-delay: calc(var(--i) * 60ms);
  }

  .blog-grid.animate .pc {
    opacity: 0;
    transform: translateY(20px);
  }

  .blog-grid.animate.visible .pc {
    opacity: 1;
    transform: translateY(0);
  }

  .pc-img-wrap {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background-color: rgba(23, 22, 22, 0.06);
    margin-bottom: 0.875rem;
  }

  .pc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    color: transparent;
    transition: transform 0.5s var(--ease-out);
  }

  .pc:hover .pc-img {
    transform: scale(1.04);
  }

  .pc-date {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin: 0 0 0.5rem;
  }

  .pc-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0;
    transition: color 0.2s ease;
  }

  .pc:hover .pc-title {
    color: var(--color-brand-red);
  }
</style>
