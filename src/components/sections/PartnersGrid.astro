---
import { partners, categories } from "../../lib/partners";
---

<section class="pg-section">
  <div class="pg-inner">

    <div class="pg-header">
      <span class="pg-eyebrow">Our Partners</span>
      <h2 class="pg-headline">
        The organizations<br />
        behind our <em class="pg-accent">impact</em>
      </h2>
      <p class="pg-sub">
        From universities to neighbourhood houses, our partners share one mission —<br class="pg-br" />
        making Canada feel like home for every newcomer.
      </p>
    </div>

    <!-- Filter tabs -->
    <div class="pg-filters" role="group" aria-label="Filter partners by category">
      <button class="pg-filter is-active" data-filter="all">All Partners</button>
      {categories.map((cat) => (
        <button class="pg-filter" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <!-- Partner grid -->
    <div class="pg-grid" id="pg-grid">
      {partners.map((p) => (
        <a
          href={`/partners/${p.slug}`}
          class="pg-card"
          data-category={p.category}
          aria-label={p.name}
        >
          <div class="pg-card-logo-wrap">
            <img src={p.logo} alt={p.name} class="pg-card-logo" loading="lazy" />
          </div>
          <div class="pg-card-body">
            <span class="pg-card-badge">{p.category}</span>
            <h3 class="pg-card-name">{p.name}</h3>
            <p class="pg-card-desc">
              {p.orgDescription.length > 100
                ? p.orgDescription.slice(0, 97) + "…"
                : p.orgDescription}
            </p>
          </div>
          <span class="pg-card-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>

    <p class="pg-empty" id="pg-empty" aria-live="polite" hidden>
      No partners in this category yet.
    </p>

  </div>
</section>

<script>
  function initGrid() {
    const filters = document.querySelectorAll<HTMLButtonElement>(".pg-filter");
    const cards = document.querySelectorAll<HTMLAnchorElement>(".pg-card");
    const emptyMsg = document.getElementById("pg-empty");

    filters.forEach((btn) => {
      const newBtn = btn.cloneNode(true) as HTMLButtonElement;
      btn.parentNode?.replaceChild(newBtn, btn);
    });

    const freshFilters = document.querySelectorAll<HTMLButtonElement>(".pg-filter");
    freshFilters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const cat = btn.dataset.filter ?? "all";
        freshFilters.forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");

        let visible = 0;
        cards.forEach((card) => {
          const matches = cat === "all" || card.dataset.category === cat;
          card.hidden = !matches;
          if (matches) visible++;
        });

        if (emptyMsg) emptyMsg.hidden = visible > 0;
      });
    });
  }

  document.addEventListener("astro:page-load", initGrid);
</script>

<style>
  .pg-section {
    background: var(--color-cream);
    padding: 5rem 2rem 6rem;
    border-top: 1px solid rgba(23, 22, 22, 0.07);
  }

  .pg-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header */
  .pg-header {
    margin-bottom: 3rem;
  }

  .pg-eyebrow {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin-bottom: 0.75rem;
  }

  .pg-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: var(--tracking-tight);
    color: var(--color-ink);
    margin: 0 0 1rem;
    line-height: 1.05;
  }

  .pg-accent {
    color: var(--color-brand-red);
    font-style: italic;
  }

  .pg-sub {
    font-family: var(--font-display);
    font-size: clamp(0.9375rem, 1.6vw, 1.0625rem);
    color: var(--color-muted);
    line-height: 1.65;
    margin: 0;
  }

  .pg-br {
    display: none;
  }

  /* Filters */
  .pg-filters {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.25rem;
  }

  .pg-filters::-webkit-scrollbar {
    display: none;
  }

  .pg-filter {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
    color: var(--color-muted);
    background: transparent;
    border: 1px solid rgba(23, 22, 22, 0.18);
    border-radius: 99px;
    padding: 0.4rem 1rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .pg-filter:hover {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }

  .pg-filter.is-active {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: #fff;
  }

  /* Grid */
  .pg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .pg-card {
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid rgba(23, 22, 22, 0.1);
    border-radius: 8px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s ease, transform 0.2s var(--ease-out), box-shadow 0.2s ease;
    position: relative;
  }

  .pg-card:hover {
    border-color: rgba(23, 22, 22, 0.25);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -8px rgba(23, 22, 22, 0.1);
  }

  .pg-card-logo-wrap {
    height: 52px;
    display: flex;
    align-items: center;
  }

  .pg-card-logo {
    max-height: 44px;
    max-width: 120px;
    width: auto;
    object-fit: contain;
    filter: grayscale(0.15);
    transition: filter 0.2s ease;
  }

  .pg-card:hover .pg-card-logo {
    filter: grayscale(0);
  }

  .pg-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .pg-card-badge {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
  }

  .pg-card-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-ink);
    margin: 0;
    line-height: 1.3;
  }

  .pg-card-desc {
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }

  .pg-card-arrow {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-brand-red);
    align-self: flex-end;
    opacity: 0;
    transition: opacity 0.15s ease, transform 0.15s ease;
    transform: translateX(-4px);
  }

  .pg-card:hover .pg-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .pg-empty {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    color: var(--color-muted);
    text-align: center;
    padding: 3rem 0;
  }

  @media (max-width: 479px) {
    .pg-section {
      padding: 3.5rem 1.25rem 4.5rem;
    }
  }

  @media (min-width: 600px) {
    .pg-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 810px) {
    .pg-section {
      padding: 5.5rem 3rem 7rem;
    }

    .pg-br {
      display: inline;
    }
  }

  @media (min-width: 1000px) {
    .pg-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1400px) {
    .pg-section {
      padding: 6rem 5rem 8rem;
    }
  }
</style>
