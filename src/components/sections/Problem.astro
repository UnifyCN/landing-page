---

---

<section class="problem bg-ink relative overflow-hidden pt-20 pb-20 desktop:pt-40 desktop:pb-28">
  <div class="problem-blob" aria-hidden="true">
    <img src="/assets/blobs/blob-11.svg" alt="" />
  </div>
  <div class="mx-auto max-w-layout px-6 desktop:px-16 relative" style="z-index:1">
    <div class="mx-auto max-w-3xl desktop:max-w-4xl">
      <p class="problem-quote">
        "You just arrived.<br />
        There's too much information,<br />
        too many opinions,<br />
        and no clear first step."
      </p>

      <p class="problem-tagline">
        That's the gap Unify fills.
      </p>
    </div>
  </div>
</section>

<style>
  .problem-blob {
    position: absolute;
    bottom: -15%;
    right: -10%;
    width: 48rem;
    pointer-events: none;
    user-select: none;
    opacity: 0.06;
    transform: rotate(25deg);
    z-index: 0;
  }
  .problem-blob img { width: 100%; height: auto; }

  .problem-quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    font-size: var(--text-problem-mobile);
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    color: #ffffff;
    text-align: center;
    margin: 0;
    text-wrap: balance;
    transition: opacity 0.75s var(--ease-out), transform 0.75s var(--ease-out);
  }

  .problem-tagline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.375rem;
    color: var(--color-brand-red);
    text-align: center;
    margin: 2.75rem 0 0;
    letter-spacing: -0.01em;
    transition: opacity 0.65s var(--ease-out) 0.3s, transform 0.65s var(--ease-out) 0.3s;
  }

  /* JS adds .animate → hide initially, then .visible → transition to visible */
  .problem.animate .problem-quote,
  .problem.animate .problem-tagline {
    opacity: 0;
    transform: translateY(24px);
  }

  .problem.animate.visible .problem-quote,
  .problem.animate.visible .problem-tagline {
    opacity: 1;
    transform: translateY(0);
  }

  @media (min-width: 810px) {
    .problem-tagline {
      font-size: 1.625rem;
    }
  }

  @media (min-width: 1400px) {
    .problem-quote {
      font-size: 3.125rem;
      line-height: 1.16;
    }

    .problem-tagline {
      font-size: 1.875rem;
      margin-top: 3.5rem;
    }
  }
</style>

<script>
  const section = document.querySelector(".problem");
  if (section) {
    section.classList.add("animate");
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.15 },
    );
    observer.observe(section);
  }
</script>
