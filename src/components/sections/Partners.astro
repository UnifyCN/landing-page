---
const partners = [
  { src: "/assets/images/partners/rbc_foundation.png", alt: "RBC Foundation" },
  {
    src: "/assets/images/partners/newcomer_jobs_canada.png",
    alt: "Newcomer Jobs Canada",
  },
  {
    src: "/assets/images/partners/global_connect_immigration.png",
    alt: "Global Connect Immigration",
  },
  { src: "/assets/images/partners/sfu.png", alt: "SFU" },
  { src: "/assets/images/partners/ey.png", alt: "EY" },
  { src: "/assets/images/partners/enactus.png", alt: "Enactus" },
  {
    src: "/assets/images/partners/fraser_international_college.png",
    alt: "Fraser International College",
  },
  {
    src: "/assets/images/partners/burnaby_neighbourhood_house.avif",
    alt: "Burnaby Neighbourhood House",
  },
  {
    src: "/assets/images/partners/surrey_libraries.png",
    alt: "Surrey Libraries",
  },
  {
    src: "/assets/images/partners/trout_lake_community_centre.png",
    alt: "Trout Lake Community Centre",
  },
  { src: "/assets/images/partners/united_way_bc.png", alt: "United Way BC" },
  {
    src: "/assets/images/partners/vancouver_public_library.png",
    alt: "Vancouver Public Library",
  },
  { src: "/assets/images/partners/ymca_bc.png", alt: "YMCA BC" },
  { src: "/assets/images/partners/capilano_university.avif", alt: "Capilano University" },
  { src: "/assets/images/partners/burnaby_public_library.png", alt: "Burnaby Public Library" },
  { src: "/assets/images/partners/promise_vancouver.png", alt: "Promise Vancouver" },
  { src: "/assets/images/partners/big_brothers_big_sisters.avif", alt: "Big Brothers Big Sisters" },
];
---

<section class="partners bg-white py-14 desktop:py-20">
  <p class="partners-label">
    Our Partners
  </p>

  <div class="partners-track-wrapper">
    <div class="partners-track">
      {
        partners.map((p) => (
          <img src={p.src} alt={p.alt} class="partner-logo" loading="lazy" />
        ))
      }
      {
        partners.map((p) => (
          <img src={p.src} alt="" class="partner-logo" loading="lazy" aria-hidden="true" />
        ))
      }
    </div>
  </div>
</section>

<style>
  .partners-label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 3rem;
  }

  .partners-track-wrapper {
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .partners-track {
    display: flex;
    align-items: center;
    gap: 5.5rem;
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  /* Pause on hover for entire track */
  @media (hover: hover) and (pointer: fine) {
    .partners-track-wrapper:hover .partners-track {
      animation-play-state: paused;
    }
  }

  .partner-logo {
    height: 56px;
    width: auto;
    flex-shrink: 0;
    opacity: 0.85;
    transition: opacity 0.25s ease, transform 0.25s var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .partner-logo:hover {
      opacity: 1;
      transform: translateY(-2px);
    }
  }

  @media (min-width: 810px) {
    .partner-logo {
      height: 64px;
    }
  }

  @media (min-width: 1400px) {
    .partner-logo {
      height: 72px;
    }
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Pause marquee when offscreen — saves compositor cycles when not visible */
  .partners.is-offscreen .partners-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .partners-track {
      animation: none;
    }
  }
</style>

<script>
  function initPartnersMarquee() {
    const section = document.querySelector<HTMLElement>(".partners");
    if (!section || section.dataset.partnersInit) return;
    section.dataset.partnersInit = "1";
    section.classList.add("is-offscreen");
    const observer = new IntersectionObserver(
      ([entry]) => {
        section.classList.toggle("is-offscreen", !entry.isIntersecting);
      },
      { threshold: 0 },
    );
    observer.observe(section);
  }

  document.addEventListener("astro:page-load", initPartnersMarquee);
</script>
