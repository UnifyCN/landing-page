---
const APP_STORE_URL =
  "https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762";
---

<section class="hero relative bg-white pt-20 pb-12 desktop:pt-28 desktop:pb-0">
  <div class="mx-auto max-w-layout px-6 desktop:px-16">
    <div
      class="flex flex-col-reverse tablet:flex-row items-center gap-8 desktop:gap-10"
    >
      <div class="hero-content flex flex-col gap-6 desktop:gap-8">
        <h1
          class="font-display font-bold text-h1-mobile desktop:text-h1 leading-none tracking-cta text-text"
        >
          <span class="hero-line hero-line-1 block"
            >The all-in-one newcomer</span
          >
          <span class="hero-line hero-line-2 block">settlement app</span>
        </h1>

        <p class="hero-subtext font-display text-xl text-muted leading-relaxed">
          Unify makes settling in Canada simpler, clearer, and more connected
        </p>

        <div class="hero-badge flex flex-col items-start gap-2">
          <a
            href={APP_STORE_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Download Unify on the App Store"
          >
            <img
              src="/assets/app-store-badge-en.svg"
              alt="Download on the App Store"
              class="h-13 w-auto"
            />
          </a>
          <p class="font-display text-micro text-muted">
            No credit card required
          </p>
        </div>
      </div>

      <div class="hero-visual flex justify-center">
        <img
          src="/assets/screenshots/learn-hero.avif"
          alt="Unify app – Learn screen"
          class="hero-phone"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-content,
  .hero-visual {
    position: relative;
    z-index: 1;
  }

  .hero-phone {
    width: 100%;
    max-height: 360px;
    object-fit: contain;
    filter: drop-shadow(0 24px 40px rgba(23, 22, 22, 0.14));
  }

  @media (min-width: 810px) {
    .hero-content {
      flex: 55 1 0%;
    }

    .hero-visual {
      flex: 45 1 0%;
      justify-content: flex-end;
      align-self: flex-end;
    }

    .hero-phone {
      max-height: 580px;
    }
  }

  @media (min-width: 1400px) {
    .hero-content {
      margin-top: -32px;
    }

    .hero-visual {
      animation: fade-in-right 0.9s ease-out 0.3s both;
      bottom: -80px;
    }
  }

  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-right {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .hero-line-1 {
    animation: fade-up 0.6s ease-out 0.1s both;
  }

  .hero-line-2 {
    animation: fade-up 0.6s ease-out 0.25s both;
  }

  .hero-subtext {
    animation: fade-up 0.5s ease-out 0.4s both;
  }

  .hero-badge {
    animation: fade-up 0.5s ease-out 0.55s both;
  }

  @media (max-width: 1399px) {
    .hero-visual {
      animation: fade-up 0.6s ease-out 0.2s both;
    }
  }
</style>
