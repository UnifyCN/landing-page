---
const APP_STORE_URL =
  "https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762";

const avatars = [
  { initials: "JP", color: "#D4A948" },
  { initials: "MA", color: "#E47793" },
  { initials: "LO", color: "#6E54B8" },
  { initials: "RN", color: "#D84A6E" },
  { initials: "+", color: "#D4B148" },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <div class="hero-rating" aria-label="Rated 4.9 out of 5 by over 2,700 newcomers">
        <span class="hero-stars" aria-hidden="true">
          {[...Array(5)].map(() => (
            <svg viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 1.5l2.62 5.31 5.86.85-4.24 4.13 1 5.84L10 14.88l-5.24 2.75 1-5.84L1.52 7.66l5.86-.85L10 1.5z" />
            </svg>
          ))}
        </span>
        <span class="hero-rating-text">
          Rated <strong>4.9</strong> by <strong>2,700+</strong> newcomers
        </span>
      </div>

      <h1 class="hero-h1">
        The all-in-one newcomer settlement app
      </h1>

      <p class="hero-desc">
        Unify makes settling in Canada simpler, clearer, and more connected.
      </p>

      <div class="hero-cta-row">
        <a
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-badge-link"
          aria-label="Download Unify on the App Store"
        >
          <img
            src="/assets/app-store-badge-en.svg"
            alt="Download on the App Store"
            class="hero-badge"
          />
        </a>
        <p class="hero-note">No credit card required</p>
      </div>

      <div class="hero-social">
        <div class="hero-avatars" aria-hidden="true">
          {avatars.map((a) => (
            <span class="hero-avatar" style={`background-color: ${a.color};`}>
              {a.initials}
            </span>
          ))}
        </div>
        <p class="hero-social-text">
          Join 2,700+ newcomers settling in from 84 countries
        </p>
      </div>
    </div>

    <div class="hero-visual">
      <img
        src="/assets/screenshots/learn-hero.avif"
        alt="Unify app – learn screen"
        class="hero-phone"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: #ffffff;
    padding-top: 4.5rem;
    padding-bottom: 2.5rem;
  }

  .hero-inner {
    position: relative;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  /* ── Rating pill ── */
  .hero-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.875rem 0.5rem 0.75rem;
    background-color: #ffffff;
    border: 1px solid rgba(23, 22, 22, 0.1);
    border-radius: 9999px;
    box-shadow: 0 1px 2px rgba(23, 22, 22, 0.04);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.1s forwards;
  }

  .hero-stars {
    display: inline-flex;
    gap: 0.125rem;
    color: #F5A623;
  }

  .hero-stars svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  .hero-rating-text {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-text);
    letter-spacing: -0.005em;
    line-height: 1;
  }

  .hero-rating-text strong {
    font-weight: 700;
  }

  /* ── Headline ── */
  .hero-h1 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7.5vw, 5.5rem);
    line-height: 1.02;
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
    text-wrap: balance;
    opacity: 0;
    animation: hero-fade-up 0.6s var(--ease-out) 0.22s forwards;
  }

  .hero-h1 em {
    font-style: italic;
    font-weight: 700;
  }

  /* ── Body copy ── */
  .hero-desc {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.1875rem);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 1.5rem 0 0;
    max-width: 44ch;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.36s forwards;
  }

  /* ── CTA row ── */
  .hero-cta-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 2rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.46s forwards;
  }

  .hero-badge-link {
    display: inline-block;
    transition: transform 0.2s var(--ease-out), filter 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .hero-badge-link:hover {
      transform: translateY(-2px) scale(1.03);
      filter: drop-shadow(0 6px 16px rgba(23, 22, 22, 0.15));
    }
  }

  .hero-badge-link:active {
    transform: scale(0.97);
  }

  .hero-badge {
    height: 52px;
    width: auto;
    display: block;
  }

  .hero-note {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: var(--color-muted);
    opacity: 0.7;
    margin: 0;
  }

  /* ── Social proof row ── */
  .hero-social {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.75rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.56s forwards;
  }

  .hero-avatars {
    display: inline-flex;
  }

  .hero-avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-family: var(--font-display);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 2px solid #ffffff;
    box-shadow: 0 1px 2px rgba(23, 22, 22, 0.06);
  }

  .hero-avatar + .hero-avatar {
    margin-left: -0.5rem;
  }

  .hero-social-text {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.4;
  }

  /* ── Phone ── */
  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    opacity: 0;
    animation: hero-phone-in 0.8s var(--ease-out) 0.2s forwards;
  }

  .hero-visual::before {
    content: "";
    position: absolute;
    inset: -20% -25%;
    background: radial-gradient(
      ellipse 55% 55% at 50% 50%,
      rgba(110, 160, 215, 0.55) 0%,
      rgba(125, 170, 215, 0.35) 35%,
      rgba(140, 180, 220, 0.15) 60%,
      rgba(147, 180, 220, 0) 80%
    );
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    animation: hero-glow-in 1.2s var(--ease-out) 0.4s forwards;
  }

  @keyframes hero-glow-in {
    to { opacity: 0.92; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-visual::before {
      animation: none;
      opacity: 0.92;
    }
  }

  .hero-phone {
    position: relative;
    z-index: 1;
    width: 100%;
    max-height: 360px;
    object-fit: contain;
    filter: drop-shadow(0 28px 48px rgba(23, 22, 22, 0.16));
  }

  /* ── Entrance animations ── */
  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes hero-phone-in {
    from { opacity: 0; transform: translateX(32px) translateY(12px); }
    to   { opacity: 1; transform: none; }
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .hero {
      padding-top: 5rem;
      padding-bottom: 3rem;
    }

    .hero-inner {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding: 0 3rem;
      align-items: center;
    }

    .hero-visual {
      justify-content: center;
    }

    .hero-phone {
      max-height: 540px;
    }

    .hero-avatar {
      width: 2.25rem;
      height: 2.25rem;
      font-size: 0.6875rem;
    }

    .hero-social-text {
      font-size: 0.875rem;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .hero {
      padding-top: 5.5rem;
      padding-bottom: 4rem;
    }

    .hero-inner {
      grid-template-columns: 1fr 480px;
      gap: 1rem;
      padding: 0 5rem;
      align-items: center;
    }

    .hero-visual {
      justify-content: center;
    }

    .hero-phone {
      max-height: 680px;
      max-width: 380px;
    }
  }
</style>
