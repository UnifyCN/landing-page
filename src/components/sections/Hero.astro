---
const APP_STORE_URL =
  "https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762";
---

<section class="hero">
  <div class="hero-blob" aria-hidden="true">
    <img src="/assets/blobs/blob-3.svg" alt="" />
  </div>

  <div class="hero-inner">
    <div class="hero-text">
      <p class="hero-overline">Newcomer settlement app</p>

      <h1 class="hero-h1">
        <span class="hero-h1-small">The all-in-one</span>
        <strong class="hero-h1-big">newcomer</strong>
        <span class="hero-h1-sub">settlement <em>app</em></span>
      </h1>

      <p class="hero-desc">
        Unify makes settling in Canada simpler, clearer, and more connected
      </p>

      <div class="hero-cta-row">
        <a
          href={APP_STORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-badge-link"
          aria-label="Download Unify on the App Store"
        >
          <img
            src="/assets/app-store-badge-en.svg"
            alt="Download on the App Store"
            class="hero-badge"
          />
        </a>
        <p class="hero-note">No credit card required</p>
      </div>
    </div>

    <div class="hero-visual">
      <img
        src="/assets/screenshots/learn-hero.avif"
        alt="Unify app – learn screen"
        class="hero-phone"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: var(--color-cream);
    overflow: hidden;
    padding-top: 4.5rem;
    padding-bottom: 0;
  }

  /* Decorative blob — top right, warm tint */
  .hero-blob {
    position: absolute;
    top: -8%;
    right: -8%;
    width: 52%;
    max-width: 640px;
    opacity: 0.28;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    filter: hue-rotate(-10deg) saturate(0.6);
  }

  .hero-blob img {
    width: 100%;
    height: auto;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  /* ── Overline ── */
  .hero-overline {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin: 0 0 1.25rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.1s forwards;
  }

  /* ── Headline ── */
  .hero-h1 {
    margin: 0;
    line-height: 0.92;
  }

  .hero-h1-small {
    display: block;
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.125rem, 2.2vw, 1.75rem);
    letter-spacing: -0.01em;
    color: var(--color-muted);
    margin-bottom: 0.25rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.18s forwards;
  }

  .hero-h1-big {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3.5rem, 10.5vw, 9rem);
    letter-spacing: var(--tracking-display);
    line-height: 0.88;
    color: var(--color-text);
    opacity: 0;
    animation: hero-fade-up 0.6s var(--ease-out) 0.24s forwards;
  }

  .hero-h1-sub {
    display: block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 4.8vw, 4.25rem);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-top: 0.375rem;
    opacity: 0;
    animation: hero-fade-up 0.6s var(--ease-out) 0.3s forwards;
  }

  .hero-h1-sub em {
    font-style: italic;
    color: var(--color-brand-red);
  }

  /* ── Body copy ── */
  .hero-desc {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.1875rem);
    line-height: 1.65;
    color: var(--color-muted);
    margin: 1.75rem 0 0;
    max-width: 44ch;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.42s forwards;
  }

  /* ── CTA row ── */
  .hero-cta-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 2.25rem;
    opacity: 0;
    animation: hero-fade-up 0.5s var(--ease-out) 0.52s forwards;
  }

  .hero-badge-link {
    display: inline-block;
    transition: transform 0.2s var(--ease-out), filter 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .hero-badge-link:hover {
      transform: translateY(-2px) scale(1.03);
      filter: drop-shadow(0 6px 16px rgba(23, 22, 22, 0.15));
    }
  }

  .hero-badge-link:active {
    transform: scale(0.97);
  }

  .hero-badge {
    height: 52px;
    width: auto;
    display: block;
  }

  .hero-note {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: var(--color-muted);
    opacity: 0.65;
    margin: 0;
  }

  /* ── Phone ── */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    opacity: 0;
    animation: hero-phone-in 0.8s var(--ease-out) 0.2s forwards;
  }

  .hero-phone {
    width: 100%;
    max-height: 360px;
    object-fit: contain;
    filter: drop-shadow(0 28px 48px rgba(23, 22, 22, 0.16));
  }

  /* ── Entrance animations ── */
  @keyframes hero-fade-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-phone-in {
    from {
      opacity: 0;
      transform: translateX(32px) translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateX(0) translateY(0);
    }
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .hero {
      padding-top: 5rem;
    }

    .hero-inner {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding: 0 3rem;
      align-items: center;
    }

    .hero-visual {
      justify-content: center;
    }

    .hero-phone {
      max-height: 540px;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .hero {
      padding-top: 5.5rem;
    }

    .hero-inner {
      /* Wider right column brings phone closer to text */
      grid-template-columns: 1fr 480px;
      gap: 1rem;
      padding: 0 5rem;
      align-items: center;
    }

    .hero-blob {
      right: -4%;
      width: 42%;
    }

    .hero-visual {
      justify-content: center;
    }

    .hero-phone {
      max-height: 680px;
      max-width: 380px;
    }
  }
</style>
