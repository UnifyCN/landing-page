---
const cards = [
  {
    icon: "/assets/images/about/book.png",
    title: "Scattered information",
    body: "62% of newly arrived newcomers report struggling to find the settlement resources they need. With government sites, Reddit threads, and WhatsApp chats all giving different answers, it's hard to know what's current or relevant — whether you're looking for help with housing, banking, jobs, or your SIN number.",
    source: "Statistics Canada, General Social Survey on Social Identity, 2020",
  },
  {
    icon: "/assets/images/about/human.png",
    title: "Doing it alone",
    body: "Starting over in a new country is hard enough — but doing it without a supportive newcomer community to lean on makes it even more overwhelming. 70% of newcomers and international students in Canada struggle to adapt because of cultural differences and language barriers.",
    source: "Canadian Index for Measuring Integration",
  },
  {
    icon: "/assets/images/about/arrows-split.png",
    title: "No clear roadmap",
    body: "Without step by step guidance, it's easy to waste time, miss IRCC deadlines, or make costly mistakes on your newcomer journey in Canada.",
    source: null,
    span: "full",
  },
];

// SSR letter split for the headline. Pre-computing transition-delay per
// letter at render time means the letter spans exist in the initial HTML —
// no FOUC and no runtime DOM thrash.
type Token =
  | { kind: "space"; text: string }
  | { kind: "word"; letters: { ch: string; delay: number }[] };

const LETTER_STAGGER = 0.014;
const LETTER_BASE = 0.2;

function tokenize(text: string, startIndex: number): { tokens: Token[]; nextIndex: number } {
  const tokens: Token[] = [];
  let i = startIndex;
  for (const part of text.split(/(\s+)/)) {
    if (part.length === 0) continue;
    if (/^\s+$/.test(part)) {
      tokens.push({ kind: "space", text: part });
      continue;
    }
    const letters = [...part].map((ch) => {
      const delay = LETTER_BASE + i * LETTER_STAGGER;
      i++;
      return { ch, delay };
    });
    tokens.push({ kind: "word", letters });
  }
  return { tokens, nextIndex: i };
}

const strong = tokenize("Settling in Canada", 0);
const muted = tokenize("feels harder than it should", strong.nextIndex);
const lastLetterDelay = LETTER_BASE + (muted.nextIndex - 1) * LETTER_STAGGER;
// Sub paragraph and cards begin their fade at the same moment as the last
// letter of "feels harder than it should" — so they arrive together with
// the headline rather than after it.
const subDelay = lastLetterDelay.toFixed(3);
const cardBaseDelay = lastLetterDelay;
---

<section class="ap">
  <div class="ap-inner">
    <!-- Heading -->
    <div class="ap-head">
      <span class="ap-pill">The Problem</span>
      <h2 class="ap-headline">
        <span class="ap-headline-strong">
          {strong.tokens.map((tok) =>
            tok.kind === "space" ? (
              tok.text
            ) : (
              <span class="ap-word">
                {tok.letters.map((l) => (
                  <span class="ap-letter" style={`transition-delay:${l.delay.toFixed(3)}s`}>{l.ch}</span>
                ))}
              </span>
            )
          )}
        </span><br />
        <span class="ap-headline-muted">
          {muted.tokens.map((tok) =>
            tok.kind === "space" ? (
              tok.text
            ) : (
              <span class="ap-word">
                {tok.letters.map((l) => (
                  <span class="ap-letter" style={`transition-delay:${l.delay.toFixed(3)}s`}>{l.ch}</span>
                ))}
              </span>
            )
          )}
        </span>
      </h2>
      <p class="ap-sub" style={`transition-delay:${subDelay}s`}>
        Moving to a new country is more than paperwork – it's rebuilding your life from scratch. Yet most newcomers run into three avoidable problems:
      </p>
    </div>

    <!-- 3-box grid -->
    <div class="ap-grid">
      {cards.map((card) => (
        <article
          class={`ap-card ${card.span === "full" ? "ap-card-full" : ""}`}
          style={`transition-delay:${cardBaseDelay.toFixed(3)}s`}
        >
          <div class="ap-card-head">
            <img src={card.icon} alt="" class="ap-card-icon" aria-hidden="true" />
            <h3 class="ap-card-title">{card.title}</h3>
          </div>
          <p class="ap-card-body">{card.body}</p>
          {card.source && <p class="ap-card-source">{card.source}</p>}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .ap {
    background-color: #ffffff;
    padding: 5rem 0 6rem;
  }

  .ap-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Heading ── */
  .ap-head {
    text-align: center;
    margin: 0 auto 4rem;
    max-width: 880px;
  }

  .ap-pill {
    display: inline-block;
    background-color: rgba(0, 0, 0, 0.04);
    color: var(--color-text);
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .ap-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    margin: 0 0 1.75rem;
  }

  .ap-headline-strong { color: var(--color-text); }
  .ap-headline-muted  { color: var(--color-muted); }

  .ap-sub {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.65;
    color: var(--color-muted);
    margin: 0 auto;
    max-width: 56ch;
  }

  /* ── Grid ── */
  .ap-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .ap-card {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 1.75rem;
    background-color: #ffffff;
    display: flex;
    flex-direction: column;
  }

  .ap-card-head {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .ap-card-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .ap-card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.75vw, 1.5rem);
    color: var(--color-text);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ap-card-body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    flex: 1;
  }

  .ap-card-source {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
  }

  .ap-card-full .ap-card-body {
    margin-bottom: 0;
  }

  /* ── Reveal animation ──
     Hidden state is gated on html.js-anim so the inline script that runs
     before the section paints can apply it pre-paint. .visible flips it.
     Per-element transition-delay is set inline via SSR. */
  .ap-pill {
    transition:
      opacity 0.7s var(--ease-out),
      transform 0.7s var(--ease-out);
  }

  .ap-sub,
  .ap-card {
    transition:
      opacity 1.4s var(--ease-out),
      transform 1.4s var(--ease-out);
  }

  .ap-word {
    display: inline-block;
    white-space: nowrap;
  }

  .ap-letter {
    display: inline-block;
    transition:
      opacity 0.55s var(--ease-out),
      transform 0.8s cubic-bezier(0.22, 1.18, 0.36, 1);
  }

  body.js-ready .ap .ap-pill,
  body.js-ready .ap .ap-sub,
  body.js-ready .ap .ap-card {
    opacity: 0;
    transform: translateY(22px);
  }

  body.js-ready .ap .ap-letter {
    opacity: 0;
    transform: translateX(-16px);
  }

  body.js-ready .ap.visible .ap-pill,
  body.js-ready .ap.visible .ap-sub,
  body.js-ready .ap.visible .ap-card {
    opacity: 1;
    transform: translateY(0);
  }

  body.js-ready .ap.visible .ap-letter {
    opacity: 1;
    transform: translateX(0);
  }

  body.js-ready .ap.visible .ap-pill { transition-delay: 0.05s; }

  @media (prefers-reduced-motion: reduce) {
    body.js-ready .ap .ap-pill,
    body.js-ready .ap .ap-sub,
    body.js-ready .ap .ap-card,
    body.js-ready .ap .ap-letter {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .ap {
      padding: 6rem 0 7rem;
    }

    .ap-inner {
      padding: 0 3rem;
    }

    .ap-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .ap-card {
      padding: 2rem;
    }

    .ap-card-full {
      grid-column: 1 / -1;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .ap-inner {
      padding: 0 5rem;
    }

    .ap-grid {
      gap: 1.75rem;
    }

    .ap-card {
      padding: 2.25rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    document.body.classList.add("js-ready");
    const section = document.querySelector<HTMLElement>(".ap");
    if (!section || section.classList.contains("visible") || section.dataset.apBound) return;
    section.dataset.apBound = "1";
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    observer.observe(section);
  });
</script>
