---
// Per-word reveal: each word slides up + fades in with a short stagger.
// 13 word spans total (vs 78 letter spans previously) — far cheaper to
// animate AND visually richer because the eye actually catches each word
// arriving.
const phrase1Words = "Take the guesswork out of your newcomer journey with".split(" ");
const phrase2Words = ["the", "full", "Unify", "experience."];

let i = 0;
const phrase1 = phrase1Words.map((word) => ({ word, i: i++ }));
const phrase2 = phrase2Words.map((word) => ({
  word,
  i: i++,
  italic: word === "Unify",
}));
---

<section class="ao">
  <div class="ao-inner">
    <h2 class="ao-headline">
      <span class="ao-headline-strong">
        {phrase1.map((w, wi) => (
          <>
            <span class="ao-word" style={`--i:${w.i}`}>{w.word}</span>
            {wi < phrase1.length - 1 && " "}
          </>
        ))}
      </span>{" "}<span class="ao-headline-muted">
        {phrase2.map((w, wi) => (
          <>
            <span class={`ao-word${w.italic ? " ao-italic" : ""}`} style={`--i:${w.i}`}>{w.word}</span>
            {wi < phrase2.length - 1 && " "}
          </>
        ))}
      </span>
    </h2>
    <p class="ao-sub">
      Be the first to experience Unify and shape the<br class="ao-br" />
      future of newcomer support in Canada
    </p>
  </div>
</section>

<style>
  .ao {
    background-color: #ffffff;
    padding: 6rem 0 6rem;
  }

  .ao-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .ao-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5.5vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: var(--tracking-display);
    margin: 0 auto 2rem;
    max-width: 22ch;
  }

  .ao-headline-strong { color: var(--color-text); }
  .ao-headline-muted  { color: var(--color-muted); }

  .ao-italic {
    font-style: italic;
  }

  /* Per-word slide-up + fade. 13 words, 90ms stagger, transform on px not
     em (em forces font-size resolution per frame), GPU-only properties. */
  .ao-word {
    display: inline-block;
    white-space: nowrap;
    transition:
      opacity 0.6s var(--ease-out),
      transform 0.6s var(--ease-out);
    transition-delay: calc(var(--i) * 90ms);
  }

  .ao.animate .ao-word {
    opacity: 0;
    transform: translateY(14px);
  }
  .ao.animate.visible .ao-word {
    opacity: 1;
    transform: translateY(0);
  }

  /* Sub paragraph follows the headline in. */
  .ao-sub {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.3vw, 1.125rem);
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
    transition:
      opacity 0.6s var(--ease-out) 1.4s,
      transform 0.6s var(--ease-out) 1.4s;
  }

  .ao.animate .ao-sub {
    opacity: 0;
    transform: translateY(10px);
  }
  .ao.animate.visible .ao-sub {
    opacity: 1;
    transform: translateY(0);
  }

  /* After reveal completes, drop transitions so browser releases per-word
     compositor layers it was keeping primed. */
  .ao.done .ao-word,
  .ao.done .ao-sub {
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ao .ao-word,
    .ao .ao-sub {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .ao {
      padding: 7rem 0 7rem;
    }

    .ao-inner {
      padding: 0 3rem;
    }

    .ao-headline {
      max-width: 28ch;
    }

    .ao-br {
      display: none;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .ao-inner {
      padding: 0 5rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const section = document.querySelector<HTMLElement>(".ao");
    if (!section || section.classList.contains("animate")) return;
    section.classList.add("animate");
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("visible");
          observer.disconnect();
          // After the word stagger (~13 * 90ms + 0.6s transition + sub
          // delay 1.4s + 0.6s) settles, drop transitions so the browser
          // can release the per-word compositor layers.
          setTimeout(() => section.classList.add("done"), 2500);
        }
      },
      { threshold: 0.25 }
    );
    observer.observe(section);
  });
</script>
