---
// Letter-by-letter animated headline — words are kept unbreakable.
// First phrase: ink. Second phrase: muted.
const phrase1Words = ["You", "can"];
const phrase2Words = ["trust", "Unify"];

// Build a flat list of letters across both phrases so the stagger increases
// continuously left-to-right.
let i = 0;
const phrase1 = phrase1Words.map((word) => {
  const letters = [...word].map((ch) => ({ ch, i: i++ }));
  return letters;
});
const phrase2 = phrase2Words.map((word) => {
  const letters = [...word].map((ch) => ({ ch, i: i++ }));
  return letters;
});

const promises = [
  {
    icon: "/assets/images/about/handshake.png",
    title: "Built on trusted sources",
    body:
      "Our lessons and AI answers are curated from reputable sources such as the Government of Canada, Immigration Refugees Citizenship Canada (IRCC), provincial newcomer sites, Service Canada, CRA, public universities, and established settlement organizations.",
  },
  {
    icon: "/assets/images/about/hyperlink.png",
    title: "Source-first answers",
    body: "We show you where information comes from so you can verify it yourself.",
  },
  {
    icon: "/assets/images/about/human.png",
    title: "Human-reviewed & updated",
    body: "We maintain a vetted knowledge base and update content as soon as policies change.",
  },
];
---

<section class="av">
  <div class="av-inner">
    <!-- Heading -->
    <div class="av-head">
      <span class="av-pill">Our Promises</span>
      <h2 class="av-headline reveal-letters">
        <span class="av-headline-strong">
          {phrase1.map((word, wi) => (
            <>
              <span class="rl-word">
                {word.map((l) => (
                  <span class="rl-char" style={`--i:${l.i}`}>{l.ch}</span>
                ))}
              </span>
              {wi < phrase1.length - 1 && " "}
            </>
          ))}
        </span>{" "}<span class="av-headline-muted">
          {phrase2.map((word, wi) => (
            <>
              <span class="rl-word">
                {word.map((l) => (
                  <span class="rl-char" style={`--i:${l.i}`}>{l.ch}</span>
                ))}
              </span>
              {wi < phrase2.length - 1 && " "}
            </>
          ))}
        </span>
      </h2>
    </div>

    <!-- Promises list -->
    <ul class="av-list">
      {promises.map((p) => (
        <li class="av-item">
          <img src={p.icon} alt="" class="av-icon" aria-hidden="true" />
          <div class="av-text">
            <h3 class="av-item-title">{p.title}</h3>
            <p class="av-item-body">{p.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .av {
    background-color: #ffffff;
    padding: 5rem 0 6rem;
  }

  .av-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Heading ── */
  .av-head {
    text-align: center;
    margin: 0 auto 4.5rem;
  }

  .av-pill {
    display: inline-block;
    background-color: rgba(0, 0, 0, 0.04);
    color: var(--color-text);
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .av-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    margin: 0;
  }

  .av-headline-strong { color: var(--color-text); }
  .av-headline-muted  { color: var(--color-muted); }

  /* ── Letter-by-letter slide-up animation ── */
  .reveal-letters .rl-word {
    display: inline-block;
    white-space: nowrap;
  }

  .reveal-letters .rl-char {
    display: inline-block;
    transition: opacity 0.55s var(--ease-out), transform 0.55s var(--ease-out);
    transition-delay: calc(var(--i) * 24ms);
  }

  /* Default = visible. JS-gated `animate` hides; `.visible` reveals. */
  .av.animate .reveal-letters .rl-char {
    opacity: 0;
    transform: translateY(0.55em);
  }
  .av.animate.visible .reveal-letters .rl-char {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Promises list ── */
  .av-list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 920px;
    display: flex;
    flex-direction: column;
    gap: 2.75rem;
  }

  .av-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  .av-icon {
    width: 44px;
    height: 44px;
    object-fit: contain;
    margin-top: 0.25rem;
  }

  .av-item-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.25rem, 1.75vw, 1.5rem);
    color: var(--color-text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .av-item-body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .av {
      padding: 6rem 0 7rem;
    }

    .av-inner {
      padding: 0 3rem;
    }

    .av-list {
      gap: 3.25rem;
    }

    .av-item {
      grid-template-columns: 80px 1fr;
      gap: 1.5rem;
    }

    .av-icon {
      width: 48px;
      height: 48px;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .av-inner {
      padding: 0 5rem;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const section = document.querySelector<HTMLElement>(".av");
    if (!section || section.classList.contains("animate")) return;
    section.classList.add("animate");
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.25 }
    );
    observer.observe(section);
  });
</script>
