---
---

<section class="journey bg-white relative overflow-hidden pt-20 desktop:pt-32 pb-8 desktop:pb-12">
  <div class="journey-blob" aria-hidden="true">
    <img src="/assets/blobs/blob-10.svg" alt="" />
  </div>
  <div class="mx-auto max-w-layout px-6 desktop:px-16 relative" style="z-index:1">

    <div class="journey-eyebrow-wrap">
      <span class="journey-eyebrow">Core Features</span>
    </div>
    <h2 class="journey-heading">Key Benefits</h2>

    <!-- Checklist feature -->
    <div class="feature-block feature-block--checklist">
      <div class="feature-text">
        <span class="feature-pill">
          <span class="feature-dot" aria-hidden="true"></span>
          Checklist
        </span>
        <h3 class="feature-heading">Your Canadian checklist,<br />personalised to you.</h3>
        <p class="feature-desc">
          Phone plans, bank accounts, SIN, healthcare &mdash; the real list that changes depending on your status, province, and how long you've been here. No more 40-tab Google research sessions.
        </p>
        <ul class="feature-bullets">
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Persona-aware tasks for students, PRs, workers &amp; more</span>
          </li>
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>&ldquo;Learn how&rdquo; guides for every step, written in plain English</span>
          </li>
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Progress you can actually see &mdash; no lost tabs, no dead ends</span>
          </li>
        </ul>
        <a href="#" class="feature-link">
          See a sample checklist
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="feature-visual">
        <div class="feature-card">
          <span class="card-blob card-blob-tr" aria-hidden="true"></span>
          <span class="card-blob card-blob-bl" aria-hidden="true"></span>
          <img
            src="/assets/screenshots/checklist.png"
            alt="Unify app – Checklist screen"
            class="feature-card-img"
            loading="eager"
          />
        </div>
      </div>
    </div>

    <!-- AI Companion feature -->
    <div class="feature-block feature-block--companion feature-block--reverse">
      <div class="feature-text">
        <span class="feature-pill">
          <span class="feature-dot" aria-hidden="true"></span>
          AI Companion
        </span>
        <h3 class="feature-heading">Ask anything, anytime.<br />Guidance tailored to you.</h3>
        <p class="feature-desc">
          From &ldquo;how does BC transit work?&rdquo; to &ldquo;what's an MSP number?&rdquo; &mdash; ask it plainly and get answers that know where you are in Canada and how long you've been here.
        </p>
        <ul class="feature-bullets">
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Grounded in real government &amp; settlement sources</span>
          </li>
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Fact-check any claim before you act on it</span>
          </li>
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Step-by-step help with forms, applications &amp; appointments</span>
          </li>
        </ul>
        <a href="#" class="feature-link">
          Try the Companion
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="feature-visual">
        <div class="feature-card">
          <span class="card-blob card-blob-tr" aria-hidden="true"></span>
          <span class="card-blob card-blob-bl" aria-hidden="true"></span>
          <img
            src="/assets/phone-ai.png"
            alt="Unify app – AI Companion screen"
            class="feature-card-img"
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <!-- Community feature -->
    <div class="feature-block feature-block--community">
      <div class="feature-text">
        <span class="feature-pill">
          <span class="feature-dot" aria-hidden="true"></span>
          Community
        </span>
        <h3 class="feature-heading">Find your circle.<br />Meet people on<br />the same journey.</h3>
        <p class="feature-desc">
          Community Matching pairs you with a small group of newcomers on a similar path &mdash; similar background, similar stage, same city. Small circles beat big feeds, every time.
        </p>
        <ul class="feature-bullets">
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Small-group matching, not another endless feed</span>
          </li>
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Groups, events, and local news that matter where you live</span>
          </li>
          <li>
            <span class="feature-check" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none"><path d="M3.5 8.5L6.5 11.5L12.5 5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span>Real experiences from people 6 months ahead of you</span>
          </li>
        </ul>
        <a href="#" class="feature-link">
          Find your community
          <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="feature-visual">
        <div class="feature-card">
          <span class="card-blob card-blob-tr" aria-hidden="true"></span>
          <span class="card-blob card-blob-bl" aria-hidden="true"></span>
          <img
            src="/assets/screenshots/community.png"
            alt="Unify app – Community screen"
            class="feature-card-img"
            loading="lazy"
          />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .journey-blob {
    position: absolute;
    top: -5%;
    left: -8%;
    width: 40rem;
    pointer-events: none;
    user-select: none;
    opacity: 0.10;
    transform: rotate(-15deg);
    z-index: 0;
  }
  .journey-blob img { width: 100%; height: auto; }

  .journey-stages {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .journey-eyebrow-wrap {
    display: flex;
    justify-content: center;
    margin: 0 0 1.25rem;
  }

  .journey-eyebrow {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    color: var(--color-text);
    background-color: #ebebeb;
    padding: 0.5rem 1.125rem;
    border-radius: 999px;
    line-height: 1.2;
  }

  .journey-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.25rem;
    line-height: 1.06;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 5rem;
    text-wrap: balance;
  }

  /* ---- Feature block ---- */

  .feature-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin: 0 0 6rem;
    align-items: center;
    transition: opacity 0.8s var(--ease-out), transform 0.8s var(--ease-out);
  }

  body.js-ready .feature-block {
    opacity: 0;
    transform: translateY(32px);
  }

  body.js-ready .feature-block.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .feature-block:last-of-type {
    margin-bottom: 0;
  }

  .feature-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .feature-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text);
    background-color: #f3ecd9;
    border: 1px solid rgba(23, 22, 22, 0.08);
    padding: 0.4rem 0.9rem 0.4rem 0.75rem;
    border-radius: 999px;
    line-height: 1;
  }

  .feature-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-text);
    display: inline-block;
  }

  .feature-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4.6vw, 3rem);
    line-height: 1.08;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0.25rem 0 0;
    text-wrap: balance;
  }

  .feature-desc {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--color-muted);
    margin: 0;
    max-width: 34rem;
  }

  .feature-bullets {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .feature-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text);
  }

  .feature-check {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background-color: var(--color-text);
    color: #ffffff;
    display: inline-grid;
    place-items: center;
    margin-top: 2px;
  }

  .feature-check svg {
    width: 14px;
    height: 14px;
  }

  .feature-link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-text);
    text-decoration: none;
    margin-top: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.2s var(--ease-out), gap 0.25s var(--ease-out);
  }

  .feature-link:hover {
    color: var(--color-brand);
    gap: 0.7rem;
  }

  .feature-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .feature-card {
    position: relative;
    width: 100%;
    max-width: 560px;
    min-height: 580px;
    background-color: #f5eeda;
    border-radius: 28px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .card-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(0.5px);
  }

  .card-blob-tr {
    top: -22%;
    right: -18%;
    width: 62%;
    aspect-ratio: 1 / 1;
    background-color: #bdb094;
    opacity: 0.9;
  }

  .card-blob-bl {
    bottom: -26%;
    left: -18%;
    width: 56%;
    aspect-ratio: 1 / 1;
    background-color: #efcb9e;
    opacity: 0.9;
  }

  .feature-card-img {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 240px;
    height: auto;
    filter: drop-shadow(0 22px 36px rgba(23, 22, 22, 0.14));
  }

  @media (min-width: 810px) {
    .feature-block {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
      margin: 0 0 7rem;
    }

    .feature-block--reverse {
      grid-template-areas: "visual text";
    }

    .feature-block--reverse .feature-visual {
      grid-area: visual;
    }

    .feature-block--reverse .feature-text {
      grid-area: text;
    }
  }

  /* ---- AI Companion (blue) variant ---- */

  .feature-block--companion .feature-card {
    background-color: #e9ecf6;
  }

  .feature-block--companion .card-blob-tr {
    background-color: #9fafd9;
  }

  .feature-block--companion .card-blob-bl {
    background-color: #eed6e3;
  }

  .feature-block--companion .feature-dot {
    background-color: #5a6fbf;
  }

  .feature-block--companion .feature-pill {
    background-color: #eef0f9;
    border-color: rgba(90, 111, 191, 0.18);
  }

  .feature-block--companion .feature-link {
    color: #5a6fbf;
  }

  .feature-block--companion .feature-link:hover {
    color: #3f53a8;
  }

  /* Companion uses a self-contained composition image — let it drive the card */
  .feature-block--companion .feature-card {
    padding: 0;
    min-height: 0;
    aspect-ratio: 447 / 558;
    background-color: #e9ecf6;
  }

  .feature-block--companion .card-blob {
    display: none;
  }

  .feature-block--companion .feature-card-img {
    width: 100%;
    max-width: none;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: none;
  }

  @media (min-width: 1400px) {
    .feature-block--companion .feature-card {
      min-height: 0;
    }
  }

  /* ---- Community (warm cream + peach) variant ---- */

  .feature-block--community .feature-card {
    background-color: #f5e6d2;
  }

  .feature-block--community .card-blob-tr {
    background-color: #f0a878;
  }

  .feature-block--community .card-blob-bl {
    background-color: #e8b88c;
  }

  .feature-block--community .feature-dot {
    background-color: var(--color-brand);
  }

  .feature-block--community .feature-pill {
    background-color: #fdeedb;
    border-color: rgba(216, 74, 41, 0.18);
    color: var(--color-brand);
  }

  .feature-block--community .feature-link {
    color: var(--color-brand);
  }

  .feature-block--community .feature-link:hover {
    color: #b03a1f;
  }

  @media (min-width: 1400px) {
    .feature-block {
      gap: 5rem;
      margin: 0 0 8rem;
    }

    .feature-heading {
      font-size: 3rem;
    }

    .feature-desc {
      font-size: 1.125rem;
    }

    .feature-bullets li {
      font-size: 1.0625rem;
    }

    .feature-card {
      min-height: 640px;
    }

    .feature-card-img {
      max-width: 275px;
    }
  }

  .stage-label {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: #ffffff;
    background-color: var(--color-brand-red);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
  }

  .stage-quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-journey-quote-mobile);
    line-height: 1.12;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
    text-wrap: balance;
  }

  .spine {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 1rem;
    width: 2px;
    background: linear-gradient(to bottom, transparent, rgba(216, 74, 41, 0.3) 20%, rgba(216, 74, 41, 0.3) 80%, transparent);
    z-index: 0;
  }

  .journey-stage {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "text"
      "visual";
    gap: 1.5rem;
    padding-left: 3rem;
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
  }

  /* JS applies animate class — stages hidden until observed */
  body.js-ready .journey-stage {
    opacity: 0;
    transform: translateY(32px);
  }

  body.js-ready .journey-stage.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stage-0 { transition-delay: 0s; }
  .stage-1 { transition-delay: 0.12s; }
  .stage-2 { transition-delay: 0.12s; }
  .stage-3 { transition-delay: 0.12s; }

  .stage-text {
    grid-area: text;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .stage-visual {
    grid-area: visual;
    display: flex;
    justify-content: center;
  }

  .stage-phone {
    width: 100%;
    max-width: 260px;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 24px 56px -10px rgba(23, 22, 22, 0.22);
    object-fit: contain;
  }

  .stage-node {
    display: none;
  }

  .node-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-brand);
    border: 3px solid white;
    box-shadow: 0 0 0 2px var(--color-brand);
  }

  /* ---- Desktop ---- */

  @media (min-width: 1400px) {
    .journey-heading {
      font-size: 3.25rem;
      margin-bottom: 7rem;
    }

    .stage-quote {
      font-size: var(--text-journey-quote);
    }

    .journey-stages {
      gap: 7rem;
    }

    .spine {
      left: 50%;
      transform: translateX(-50%);
    }

    .journey-stage {
      grid-template-columns: 1fr 80px 1fr;
      grid-template-areas: "text node visual";
      align-items: center;
      padding-left: 0;
      gap: 0;
    }

    .journey-stage.reverse {
      grid-template-areas: "visual node text";
    }

    .stage-node {
      display: flex;
      align-items: center;
      justify-content: center;
      grid-area: node;
      position: relative;
      z-index: 1;
    }

    .stage-text {
      gap: 1rem;
    }

    .journey-stage:not(.reverse) .stage-text {
      padding-right: 3rem;
      text-align: right;
      align-items: flex-end;
    }

    .journey-stage.reverse .stage-text {
      padding-left: 3rem;
      text-align: left;
      align-items: flex-start;
    }

    .journey-stage:not(.reverse) .stage-visual {
      justify-content: flex-start;
      padding-left: 3rem;
    }

    .journey-stage.reverse .stage-visual {
      justify-content: flex-end;
      padding-right: 3rem;
    }

    .stage-phone {
      max-width: 280px;
    }
  }

  /* ---- Tablet ---- */

  @media (min-width: 810px) and (max-width: 1399px) {
    .journey-heading {
      font-size: 2.75rem;
      margin-bottom: 5.5rem;
    }

    .journey-stages {
      gap: 5rem;
    }

    .journey-stage {
      grid-template-columns: 1fr 1fr;
      grid-template-areas: "text visual";
      align-items: center;
      padding-left: 0;
      gap: 2rem;
    }

    .journey-stage.reverse {
      grid-template-areas: "visual text";
    }

    .spine {
      left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(to bottom, transparent, rgba(216, 74, 41, 0.25) 15%, rgba(216, 74, 41, 0.25) 85%, transparent);
    }

    .stage-phone {
      max-width: 240px;
    }
  }
</style>

<script>
  function initJourney() {
    document.body.classList.add("js-ready");
    const reveals = document.querySelectorAll<HTMLElement>(
      ".journey-stage, .feature-block"
    );
    if (!reveals.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );
    reveals.forEach((el) => {
      if (el.classList.contains("visible")) return;
      observer.observe(el);
    });
  }

  document.addEventListener("astro:page-load", initJourney);
</script>
