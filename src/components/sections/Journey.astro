---
const stages = [
  {
    label: "Day 1",
    quote: "You don’t know where to start.",
    screenshot: "/assets/screenshots/checklist.png",
    alt: "Unify app – Checklist screen",
  },
  {
    label: "Week 1",
    quote: "You need answers you can trust.",
    screenshot: "/assets/screenshots/companion.png",
    alt: "Unify app – AI Companion screen",
  },
  {
    label: "Month 1",
    quote: "You want to understand how life in Canada works.",
    screenshot: "/assets/screenshots/learn.png",
    alt: "Unify app – Learn screen",
  },
  {
    label: "Month 3",
    quote: "You’re ready to find belonging.",
    screenshot: "/assets/screenshots/community.png",
    alt: "Unify app – Community screen",
  },
];
---

<section class="journey bg-white py-20 desktop:py-32">
  <div class="mx-auto max-w-layout px-6 desktop:px-16">

    <p class="journey-eyebrow">How Unify fits your journey</p>
    <h2 class="journey-heading">From arrival<br>to belonging</h2>

    <div class="journey-stages">
      {stages.map((stage, i) => (
        <div class={`journey-stage stage-${i} ${i % 2 === 1 ? "reverse" : ""}`}>

          <!-- Text side -->
          <div class="stage-text">
            <span class="stage-label">{stage.label}</span>
            <p class="stage-quote">
              {stage.quote}
            </p>
          </div>

          <!-- Spine node -->
          <div class="stage-node" aria-hidden="true">
            <div class="node-dot"></div>
          </div>

          <!-- Screenshot side -->
          <div class="stage-visual">
            <img
              src={stage.screenshot}
              alt={stage.alt}
              class="stage-phone"
              loading="eager"
            />
          </div>

        </div>
      ))}

      <!-- Vertical spine line -->
      <div class="spine" aria-hidden="true"></div>
    </div>

  </div>
</section>

<style>
  .journey-stages {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .journey-eyebrow {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
    text-align: center;
    margin: 0 0 0.875rem;
  }

  .journey-heading {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.25rem;
    line-height: 1.06;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    text-align: center;
    margin: 0 0 5rem;
    text-wrap: balance;
  }

  .stage-label {
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: #ffffff;
    background-color: var(--color-brand-red);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
  }

  .stage-quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-journey-quote-mobile);
    line-height: 1.12;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
    text-wrap: balance;
  }

  .spine {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 1rem;
    width: 2px;
    background: linear-gradient(to bottom, transparent, rgba(216, 74, 41, 0.3) 20%, rgba(216, 74, 41, 0.3) 80%, transparent);
    z-index: 0;
  }

  .journey-stage {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "text"
      "visual";
    gap: 1.5rem;
    padding-left: 3rem;
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
  }

  /* JS applies animate class — stages hidden until observed */
  body.js-ready .journey-stage {
    opacity: 0;
    transform: translateY(32px);
  }

  body.js-ready .journey-stage.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stage-0 { transition-delay: 0s; }
  .stage-1 { transition-delay: 0.12s; }
  .stage-2 { transition-delay: 0.12s; }
  .stage-3 { transition-delay: 0.12s; }

  .stage-text {
    grid-area: text;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  .stage-visual {
    grid-area: visual;
    display: flex;
    justify-content: center;
  }

  .stage-phone {
    width: 100%;
    max-width: 260px;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 24px 56px -10px rgba(23, 22, 22, 0.22);
    object-fit: contain;
  }

  .stage-node {
    display: none;
  }

  .node-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-brand);
    border: 3px solid white;
    box-shadow: 0 0 0 2px var(--color-brand);
  }

  /* ---- Desktop ---- */

  @media (min-width: 1400px) {
    .journey-heading {
      font-size: 3.25rem;
      margin-bottom: 7rem;
    }

    .stage-quote {
      font-size: var(--text-journey-quote);
    }

    .journey-stages {
      gap: 7rem;
    }

    .spine {
      left: 50%;
      transform: translateX(-50%);
    }

    .journey-stage {
      grid-template-columns: 1fr 80px 1fr;
      grid-template-areas: "text node visual";
      align-items: center;
      padding-left: 0;
      gap: 0;
    }

    .journey-stage.reverse {
      grid-template-areas: "visual node text";
    }

    .stage-node {
      display: flex;
      align-items: center;
      justify-content: center;
      grid-area: node;
      position: relative;
      z-index: 1;
    }

    .stage-text {
      gap: 1rem;
    }

    .journey-stage:not(.reverse) .stage-text {
      padding-right: 3rem;
      text-align: right;
      align-items: flex-end;
    }

    .journey-stage.reverse .stage-text {
      padding-left: 3rem;
      text-align: left;
      align-items: flex-start;
    }

    .journey-stage:not(.reverse) .stage-visual {
      justify-content: flex-start;
      padding-left: 3rem;
    }

    .journey-stage.reverse .stage-visual {
      justify-content: flex-end;
      padding-right: 3rem;
    }

    .stage-phone {
      max-width: 280px;
    }
  }

  /* ---- Tablet ---- */

  @media (min-width: 810px) and (max-width: 1399px) {
    .journey-heading {
      font-size: 2.75rem;
      margin-bottom: 5.5rem;
    }

    .journey-stages {
      gap: 5rem;
    }

    .journey-stage {
      grid-template-columns: 1fr 1fr;
      grid-template-areas: "text visual";
      align-items: center;
      padding-left: 0;
      gap: 2rem;
    }

    .journey-stage.reverse {
      grid-template-areas: "visual text";
    }

    .spine {
      left: 50%;
      transform: translateX(-50%);
      background: linear-gradient(to bottom, transparent, rgba(216, 74, 41, 0.25) 15%, rgba(216, 74, 41, 0.25) 85%, transparent);
    }

    .stage-phone {
      max-width: 240px;
    }
  }
</style>

<script>
  document.body.classList.add("js-ready");
  const stages = document.querySelectorAll(".journey-stage");
  if (stages.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );
    stages.forEach((stage) => observer.observe(stage));
  }
</script>
