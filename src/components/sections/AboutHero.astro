---
const photos = [
  {
    src: "/assets/images/about/founders-portrait.avif",
    alt: "Cedric and Savar's family arriving at the airport",
  },
  {
    src: "/assets/images/about/founders-portrait2.avif",
    alt: "Cedric and Savar — founders of Unify",
  },
];
---

<section class="ah">
  <div class="ah-inner">
    <!-- ── Photo carousel ── -->
    <div class="ah-photo-col">
      <div class="ah-carousel" data-active="0" data-count={photos.length}>
        {photos.map((photo, i) => (
          <img
            src={photo.src}
            alt={photo.alt}
            class="ah-photo"
            loading={i === 0 ? "eager" : "lazy"}
            data-index={i}
          />
        ))}
      </div>
      <div class="ah-controls">
        <button class="ah-ctrl" data-dir="-1" aria-label="Previous photo">
          <span class="ah-arrow">←</span>
          <span>BACK</span>
        </button>
        <button class="ah-ctrl" data-dir="1" aria-label="Next photo">
          <span>NEXT</span>
          <span class="ah-arrow">→</span>
        </button>
      </div>
    </div>

    <!-- ── Text column ── -->
    <div class="ah-text-col">
      <p class="ah-eyebrow">
        <span class="ah-eyebrow-dash" aria-hidden="true"></span>
        <span>Our journey</span>
      </p>
      <h1 class="ah-headline">
        Hi, we're Cedric and Savar <span class="ah-wave" aria-hidden="true">👋</span>
      </h1>
      <p class="ah-body">
        We're building Unify to make settling in Canada simpler, clearer, and more connected. After hearing the same story of confusion, unclear answers, and isolation, we built one platform that brings together guidance and community support. We've experienced how confusing and isolating this journey can be. That's why we're building Unify — so no one has to figure it out alone. We hope it helps you feel at home faster and we're listening to make it better every week :)
      </p>
    </div>
  </div>
</section>

<style>
  .ah {
    background-color: #ffffff;
    padding: calc(67px + 1rem) 0 5rem;
  }

  .ah-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  /* ── Photo column ── */
  .ah-photo-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ah-carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 4px;
    background-color: rgba(0, 0, 0, 0.04);
  }

  .ah-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.6s var(--ease-out);
  }

  .ah-carousel[data-active="0"] .ah-photo[data-index="0"],
  .ah-carousel[data-active="1"] .ah-photo[data-index="1"],
  .ah-carousel[data-active="2"] .ah-photo[data-index="2"] {
    opacity: 1;
  }

  /* ── Carousel controls ── */
  .ah-controls {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
  }

  /* ── Scroll reveal (progressive enhancement) ──
     Hidden state is gated on html.js-anim, which an inline script sets
     synchronously *before* this section paints. That guarantees the
     element starts hidden — when .visible is added, the browser
     transitions from a real hidden state, not from a half-faded one. */
  @keyframes ah-fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .ah-photo-col {
    opacity: 0;
    animation: ah-fade-up 1s var(--ease-out) 0.05s forwards;
  }

  .ah-eyebrow {
    opacity: 0;
    animation: ah-fade-up 0.65s var(--ease-out) 0.18s forwards;
  }

  .ah-headline {
    opacity: 0;
    animation: ah-fade-up 0.65s var(--ease-out) 0.34s forwards;
  }

  .ah-body {
    opacity: 0;
    animation: ah-fade-up 0.65s var(--ease-out) 0.52s forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .ah-photo-col,
    .ah-eyebrow,
    .ah-headline,
    .ah-body {
      animation: none;
      opacity: 1;
    }
  }

  .ah-ctrl {
    appearance: none;
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.2s ease, gap 0.2s var(--ease-out);
  }

  .ah-ctrl:hover {
    color: var(--color-brand-red);
  }

  .ah-ctrl[data-dir="-1"]:hover { gap: 0.75rem; }
  .ah-ctrl[data-dir="1"]:hover  { gap: 0.75rem; }

  .ah-arrow {
    font-size: 1rem;
    line-height: 1;
    display: inline-block;
  }

  /* ── Text column ── */
  .ah-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ah-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.875rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-brand-red);
    margin: 0 0 1.5rem;
    letter-spacing: -0.01em;
  }

  .ah-eyebrow-dash {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: var(--color-brand-red);
  }

  .ah-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 5.5vw, 4.25rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
    margin: 0 0 1.75rem;
  }

  .ah-wave {
    display: inline-block;
    transform: translateY(-0.05em);
    margin-left: 0.25rem;
  }

  .ah-body {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 1.2vw, 1.0625rem);
    line-height: 1.75;
    color: var(--color-text);
    margin: 0;
    max-width: 56ch;
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .ah {
      padding: calc(67px + 1.5rem) 0 6rem;
    }

    .ah-inner {
      padding: 0 3rem;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .ah-carousel {
      aspect-ratio: 4 / 5;
    }

    .ah-controls {
      justify-content: flex-end;
      padding-right: 0.5rem;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .ah {
      padding: calc(67px + 2rem) 0 7rem;
    }

    .ah-inner {
      padding: 0 5rem;
      gap: 5.5rem;
    }
  }
</style>

<script>
  function initCarousel() {
    const carousels = document.querySelectorAll<HTMLElement>(".ah-carousel");
    carousels.forEach((carousel) => {
      if (carousel.dataset.ahCarouselInit) return;
      carousel.dataset.ahCarouselInit = "1";
      const count = parseInt(carousel.dataset.count ?? "1", 10);
      const controls = carousel.parentElement?.querySelectorAll<HTMLButtonElement>(".ah-ctrl");
      if (!controls || count <= 1) return;

      controls.forEach((btn) => {
        btn.addEventListener("click", () => {
          const dir = parseInt(btn.dataset.dir ?? "1", 10);
          const current = parseInt(carousel.dataset.active ?? "0", 10);
          const next = (current + dir + count) % count;
          carousel.dataset.active = String(next);
        });
      });
    });
  }

  initCarousel();
  document.addEventListener("astro:page-load", initCarousel);
</script>
