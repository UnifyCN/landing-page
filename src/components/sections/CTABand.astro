---
const APP_STORE_URL =
  "https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762";
---

<section class="cta-wrap">
  <div class="cta-blob" aria-hidden="true">
    <img src="/assets/blobs/blob-8.svg" alt="" />
  </div>
  <div class="cta-inner">
    <div class="cta-left">
      <p class="cta-eyebrow">Ready to get started?</p>
      <h2 class="cta-title">
        Stop guessing.<br />
        <em>Start settling.</em>
      </h2>
    </div>
    <div class="cta-right">
      <p class="cta-sub">
        Join thousands of newcomers who use Unify to navigate life in Canada — from day one to finding home.
      </p>
      <a
        href={APP_STORE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn"
      >
        Download the App Now
      </a>
      <p class="cta-note">Free to download. No credit card required.</p>
    </div>
  </div>
</section>

<style>
  .cta-wrap {
    position: relative;
    background-color: var(--color-ink);
    overflow: hidden;
    padding: 6rem 0 7rem;
  }

  .cta-blob {
    position: absolute;
    bottom: -20%;
    right: -10%;
    width: 55%;
    max-width: 680px;
    opacity: 0.07;
    pointer-events: none;
    user-select: none;
    filter: hue-rotate(330deg) saturate(0.4) invert(1);
  }

  .cta-blob img {
    width: 100%;
    height: auto;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    transition: opacity 0.7s var(--ease-out), transform 0.7s var(--ease-out);
  }

  body.js-ready .cta-inner {
    opacity: 0;
    transform: translateY(28px);
  }

  body.js-ready .cta-wrap.visible .cta-inner {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Left: headline ── */
  .cta-eyebrow {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-brand-red);
    margin: 0 0 1.25rem;
  }

  .cta-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.92;
    letter-spacing: var(--tracking-display);
    color: #ffffff;
    margin: 0;
  }

  .cta-title em {
    font-style: italic;
    color: var(--color-brand-red);
  }

  /* ── Right: sub + CTA ── */
  .cta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .cta-sub {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    max-width: 42ch;
  }

  .cta-btn {
    display: inline-block;
    background-color: var(--color-brand-red);
    color: #ffffff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1;
    letter-spacing: -0.01em;
    text-decoration: none;
    padding: 1rem 2rem;
    border-radius: var(--radius-cta);
    box-shadow: 0 4px 20px -4px rgba(216, 74, 41, 0.5);
    transition: transform 0.18s var(--ease-out), box-shadow 0.18s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .cta-btn:hover {
      transform: translateY(-2px) scale(1.04);
      box-shadow: 0 12px 32px -6px rgba(216, 74, 41, 0.55);
    }
  }

  .cta-btn:active {
    transform: scale(0.97);
    box-shadow: 0 2px 8px -2px rgba(216, 74, 41, 0.3);
  }

  .cta-note {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
  }

  /* ── Phone ── */
  @media (max-width: 479px) {
    .cta-wrap {
      padding: 4rem 0 5rem;
    }

    .cta-inner {
      padding: 0 1.25rem;
    }

    .cta-title {
      font-size: clamp(2.25rem, 12vw, 3rem);
    }
  }

  /* ── Tablet ── */
  @media (min-width: 810px) {
    .cta-wrap {
      padding: 7rem 0 8rem;
    }

    .cta-inner {
      padding: 0 3rem;
      flex-direction: row;
      align-items: flex-start;
      gap: 4rem;
    }

    .cta-left {
      flex: 0 0 auto;
    }

    .cta-right {
      flex: 1;
      justify-content: flex-end;
      padding-top: 0.5rem;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .cta-wrap {
      padding: 8.5rem 0 9.5rem;
    }

    .cta-inner {
      padding: 0 5rem;
      gap: 5rem;
    }

    .cta-btn {
      font-size: 1.125rem;
      padding: 1.125rem 2.25rem;
    }
  }
</style>

<script>
  const section = document.querySelector(".cta-wrap");
  if (section) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add("visible");
          observer.disconnect();
        }
      },
      { threshold: 0.12 },
    );
    observer.observe(section);
  }
</script>
