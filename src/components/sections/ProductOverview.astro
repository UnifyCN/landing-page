---
const features = [
  {
    id: "checklist",
    label: "Checklist",
    video: "/assets/demos/checklist.mp4",
    copy: "Know exactly what to do next with a personalized checklist built around your situation.",
    num: "01",
  },
  {
    id: "ai-companion",
    label: "AI Companion",
    video: "/assets/demos/ai-companion.mp4",
    copy: "Ask anything and get clear, practical answers grounded in trusted Canadian sources.",
    num: "02",
  },
  {
    id: "learn",
    label: "Learn",
    video: "/assets/demos/learn.mp4",
    copy: "Turn confusing processes into simple, step-by-step guidance you can actually follow.",
    num: "03",
  },
  {
    id: "community",
    label: "Community",
    video: "/assets/demos/community-events.mp4",
    copy: "Connect with people on the same journey and get support from those who've been there.",
    num: "04",
  },
];
---

<section class="po-wrap">
  <div class="po-blob" aria-hidden="true">
    <img src="/assets/blobs/blob-12.svg" alt="" />
  </div>
  <div class="po-inner" style="position:relative;z-index:1">
    <!-- Left: editorial column -->
    <div class="po-left">
      <header class="po-header">
        <p class="po-eyebrow">Everything in one place</p>
        <h2 class="po-title">See Unify<br />in action</h2>
      </header>

      <div class="po-list" role="tablist" aria-label="Unify features">
        {
          features.map((f, i) => (
            <button
              class={`po-item${i === 0 ? " active" : ""}`}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-controls={`pov-${f.id}`}
              data-target={f.id}
              data-num={f.num}
              type="button"
            >
              <span class="po-num">{f.num}</span>
              <span class="po-content">
                <span class="po-name">{f.label}</span>
                <span class="po-desc">{f.copy}</span>
              </span>
            </button>
          ))
        }
      </div>
    </div>

    <!-- Right: video demo -->
    <div class="po-right" aria-live="polite">
      <div class="po-stage">
        {
          features.map((f, i) => (
            <div
              class={`po-panel${i === 0 ? " active" : ""}`}
              id={`pov-${f.id}`}
              role="tabpanel"
              data-id={f.id}
              aria-hidden={i !== 0 ? "true" : undefined}
            >
              <video
                src={f.video}
                autoplay={i === 0 || undefined}
                muted
                loop
                playsinline
                preload={i === 0 ? "auto" : "metadata"}
                class="po-video"
              />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Blob ── */
  .po-blob {
    position: absolute;
    bottom: -10%;
    right: -8%;
    width: 44rem;
    pointer-events: none;
    user-select: none;
    opacity: 0.08;
    transform: rotate(10deg);
    z-index: 0;
  }
  .po-blob img { width: 100%; height: auto; }

  /* ── Shell ── */
  .po-wrap {
    background-color: var(--color-cream);
    padding: 4.5rem 0 5.5rem;
    position: relative;
    overflow: hidden;
  }

  .po-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* ── Left column ── */
  .po-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .po-eyebrow {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-muted);
    margin: 0 0 0.75rem;
  }

  .po-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-h3-mobile);
    line-height: 1.06;
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
  }

  /* ── Feature list ── */
  .po-list {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .po-item {
    display: flex;
    align-items: flex-start;
    gap: 1.125rem;
    text-align: left;
    background: none;
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding: 1.0625rem 0;
    cursor: pointer;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  /* Faint large numeral behind the active item */
  .po-item::before {
    content: attr(data-num);
    position: absolute;
    right: -0.25rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 5.5rem;
    line-height: 1;
    color: var(--color-text);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    user-select: none;
  }

  .po-item.active::before {
    opacity: 0.045;
  }

  .po-num {
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-brand-red);
    padding-top: 0.3em;
    flex-shrink: 0;
    width: 1.75rem;
    opacity: 0.55;
    transition: opacity 0.2s ease;
  }

  .po-item.active .po-num,
  .po-item:hover .po-num {
    opacity: 1;
  }

  .po-content {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .po-name {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .po-item:hover:not(.active) .po-name {
    color: var(--color-text);
  }

  .po-item.active .po-name {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text);
  }

  /* Copy expands on active */
  .po-desc {
    display: block;
    font-family: var(--font-display);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-muted);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    transition:
      max-height 0.32s ease,
      opacity 0.25s ease,
      margin-top 0.25s ease;
  }

  .po-item.active .po-desc {
    max-height: 10rem;
    opacity: 1;
    margin-top: 0.5rem;
  }

  /* ── Right: video stage ── */
  .po-right {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  /* Grid overlay: all panels share the same cell — no height reflow on switch */
  .po-stage {
    display: grid;
    width: 100%;
    max-width: 365px;
  }

  .po-panel {
    grid-column: 1;
    grid-row: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .po-panel.active {
    opacity: 1;
    pointer-events: auto;
  }

  .po-video {
    display: block;
    width: 100%;
    height: auto;
    /* drop-shadow traces the phone bezel, not a rectangular box.
       Single drop-shadow (was dual: dropped the brand-red 6%-alpha pass that
       was imperceptible but cost a full compositor pass during scroll). */
    filter: drop-shadow(0 20px 56px rgba(23, 22, 22, 0.22));
  }

  /* ── Tablet: side-by-side ── */
  @media (min-width: 810px) and (max-width: 1399px) {
    .po-wrap {
      padding: 5.5rem 0 6.5rem;
    }

    .po-inner {
      flex-direction: row;
      align-items: center;
      gap: 2.5rem;
      padding: 0 3rem;
    }

    .po-left {
      flex: 0 0 360px;
      gap: 2.25rem;
    }

    .po-right {
      flex: 1;
      justify-content: center;
      align-items: center;
    }

    .po-stage {
      max-width: 415px;
    }

    .po-title {
      font-size: 2.25rem;
    }
  }

  /* ── Desktop ── */
  @media (min-width: 1400px) {
    .po-wrap {
      padding: 7rem 0 8rem;
    }

    .po-inner {
      flex-direction: row;
      align-items: center;
      gap: 3.5rem;
      padding: 0 5rem;
    }

    .po-left {
      flex: 0 0 500px;
      gap: 3rem;
    }

    .po-right {
      flex: 1;
      justify-content: center;
      align-items: center;
    }

    .po-stage {
      max-width: 480px;
      transform: translateY(-1.5rem);
    }

    .po-title {
      font-size: var(--text-h3);
    }

    .po-eyebrow {
      font-size: 0.875rem;
    }

    .po-item {
      padding: 1.25rem 0;
      gap: 1.375rem;
    }

    .po-num {
      font-size: 0.75rem;
      width: 2rem;
      padding-top: 0.35em;
    }

    .po-name {
      font-size: 1.0625rem;
    }

    .po-item.active .po-name {
      font-size: 1.5rem;
    }

    .po-desc {
      font-size: 1rem;
    }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLButtonElement>(".po-item");
  const panels = document.querySelectorAll<HTMLElement>(".po-panel");

  items.forEach((item) => {
    item.addEventListener("click", () => {
      const target = item.dataset.target;
      if (!target || item.classList.contains("active")) return;

      items.forEach((b) => {
        b.classList.remove("active");
        b.setAttribute("aria-selected", "false");
      });

      panels.forEach((p) => {
        const v = p.querySelector("video");
        if (v) v.pause();
        p.classList.remove("active");
        p.setAttribute("aria-hidden", "true");
      });

      item.classList.add("active");
      item.setAttribute("aria-selected", "true");

      const panel = document.querySelector<HTMLElement>(
        `[data-id="${target}"]`,
      );
      if (panel) {
        panel.classList.add("active");
        panel.removeAttribute("aria-hidden");
        const v = panel.querySelector("video");
        if (v) {
          v.currentTime = 0;
          v.play().catch(() => {});
        }
      }
    });
  });
</script>
