---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Community", href: "/community" },
  { label: "Blog", href: "/blog" },
  { label: "Resources", href: "/resources" },
];
---

<!-- Sticky wrapper — pointer-events-none so it doesn't block page content below the pill -->
<div class="sticky top-5 z-50 flex justify-center px-4 pointer-events-none">
  <div
    id="nav-pill"
    class="nav-pill pointer-events-auto flex items-center justify-between desktop:justify-start w-full max-w-3xl pl-5 pr-3 py-2.5"
  >
    <!-- Logo — plain div, not a link -->
    <div class="flex-shrink-0">
      <img
        src="/assets/logo/logo-with-name.png"
        alt="Unify"
        class="h-10 w-auto"
      />
    </div>

    <!-- Desktop nav links -->
    <nav
      class="hidden desktop:flex desktop:flex-1 justify-center items-center gap-6"
      aria-label="Main navigation"
    >
      <ul role="list" class="flex items-center gap-6 list-none m-0 p-0">
        {
          navLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="nav-link font-display text-nav leading-nav tracking-nav font-semibold text-ink no-underline"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right side: CTA (desktop) + hamburger (mobile/tablet) -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href="https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn hidden desktop:flex items-center gap-2 font-ui text-nav leading-nav tracking-cta font-medium bg-ink text-cream px-btn-x py-btn-y whitespace-nowrap no-underline"
      >
        Download Unify
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 7h10M8 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="desktop:hidden flex flex-col justify-center items-center gap-1.5 w-8 h-8 bg-transparent border-0 cursor-pointer p-0"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open navigation menu"
      >
        <span class="block w-6 h-0.5 bg-ink rounded-full"></span>
        <span class="block w-6 h-0.5 bg-ink rounded-full"></span>
        <span class="block w-6 h-0.5 bg-ink rounded-full"></span>
      </button>
    </div>
  </div>
</div>

<!-- Mobile full-screen overlay -->
<div
  id="mobile-nav"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  style="display:none; z-index:60"
  class="fixed inset-0 bg-white flex-col"
>
  <!-- Top bar: logo + close -->
  <div class="px-6 h-navbar flex items-center justify-between flex-shrink-0">
    <div class="flex-shrink-0">
      <img
        src="/assets/logo/logo-with-name.png"
        alt="Unify"
        class="h-8 w-auto"
      />
    </div>
    <button
      id="nav-close"
      type="button"
      class="flex items-center justify-center w-8 h-8 bg-transparent border-0 cursor-pointer p-0 text-ink"
      aria-label="Close navigation menu"
    >
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Stacked links + CTA -->
  <nav
    class="flex-1 flex flex-col items-center justify-center gap-10"
    aria-label="Mobile navigation"
  >
    <ul role="list" class="flex flex-col items-center gap-6 list-none m-0 p-0">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="font-display text-nav leading-nav tracking-nav font-semibold text-ink no-underline"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762"
      target="_blank"
      rel="noopener noreferrer"
      class="cta-btn flex items-center gap-2 font-ui text-nav leading-nav tracking-cta font-medium bg-ink text-cream px-btn-x py-btn-y whitespace-nowrap no-underline"
    >
      Download Unify
      <svg
        width="14"
        height="14"
        viewBox="0 0 14 14"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M2 7h10M8 3l4 4-4 4"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </nav>
</div>

<style>
  .nav-pill {
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-pill);
    box-shadow: 0 10px 28px -14px rgba(23, 22, 22, 0.18);
    transition: box-shadow 0.25s ease;
  }

  .nav-pill.is-scrolled {
    box-shadow: 0 16px 36px -10px rgba(23, 22, 22, 0.28);
  }

  /* Nav link red underline grows from center on hover */
  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 100%;
    height: 2px;
    background: #d84a29;
    border-radius: 1px;
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .nav-link:hover::after {
    transform: translateX(-50%) scaleX(1);
  }

  .cta-btn {
    border-radius: var(--radius-cta);
  }
</style>

<script>
  const pill = document.getElementById("nav-pill");
  const toggle = document.getElementById("nav-toggle");
  const close = document.getElementById("nav-close");
  const menu = document.getElementById("mobile-nav");

  // Scroll: add is-scrolled class when page is not at top
  function updateScrollState() {
    if (!pill) return;
    if (window.scrollY > 10) {
      pill.classList.add("is-scrolled");
    } else {
      pill.classList.remove("is-scrolled");
    }
  }
  window.addEventListener("scroll", updateScrollState, { passive: true });
  updateScrollState();

  // Mobile menu
  function openMenu() {
    if (!menu || !toggle) return;
    menu.style.display = "flex";
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!menu || !toggle) return;
    menu.style.display = "none";
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openMenu);
  close?.addEventListener("click", closeMenu);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menu?.style.display === "flex") closeMenu();
  });
</script>
