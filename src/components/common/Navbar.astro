---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Community", href: "/community" },
  { label: "Partners", href: "/partners" },
  { label: "Blog", href: "/blog" },
  { label: "Resources", href: "/resources" },
  { label: "Contact", href: "/contact" },
];

const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<!-- Sticky wrapper — pointer-events-none so it doesn't block page content below the pill -->
<div class="sticky top-5 z-50 flex justify-center px-4 pointer-events-none">
  <div
    id="nav-pill"
    class="nav-pill pointer-events-auto flex items-center gap-6 w-auto pl-5 pr-3 py-2.5"
  >
    <!-- Logo — plain div, not a link -->
    <div class="flex-shrink-0">
      <img
        src="/assets/logo/logo-with-name.png"
        alt="Unify"
        class="h-10 w-auto"
      />
    </div>

    <!-- Desktop nav links -->
    <nav
      class="hidden desktop:flex items-center gap-6"
      aria-label="Main navigation"
    >
      <ul role="list" class="flex items-center gap-6 list-none m-0 p-0">
        {
          navLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                aria-current={isActive(href) ? "page" : undefined}
                class={`nav-link font-display text-nav leading-nav tracking-nav font-semibold text-ink no-underline${isActive(href) ? " nav-link-active" : ""}`}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right side: CTA (desktop) + hamburger (mobile/tablet) -->
    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href="https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn hidden desktop:flex items-center gap-2 font-ui text-nav leading-nav tracking-cta font-medium bg-ink text-cream px-btn-x py-btn-y whitespace-nowrap no-underline"
      >
        Download Unify
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 7h10M8 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>

      <button
        id="nav-toggle"
        type="button"
        class="hamburger desktop:hidden flex flex-col justify-center items-center w-8 h-8 bg-transparent border-0 cursor-pointer p-0 relative"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open navigation menu"
      >
        <span class="ham-line ham-line-1"></span>
        <span class="ham-line ham-line-2"></span>
        <span class="ham-line ham-line-3"></span>
      </button>
    </div>
  </div>
</div>

<!-- Mobile full-screen overlay -->
<div
  id="mobile-nav"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
  class="mobile-nav fixed inset-0 flex flex-col"
  style="z-index:60; background-color: var(--color-cream);"
>
  <!-- Top bar: logo + close -->
  <div class="px-6 h-navbar flex items-center justify-between flex-shrink-0">
    <div class="flex-shrink-0">
      <img
        src="/assets/logo/logo-with-name.png"
        alt="Unify"
        class="h-10 w-auto"
      />
    </div>
    <button
      id="nav-close"
      type="button"
      class="flex items-center justify-center w-8 h-8 bg-transparent border-0 cursor-pointer p-0 text-ink"
      aria-label="Close navigation menu"
    >
      <svg
        width="22"
        height="22"
        viewBox="0 0 22 22"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="17" y1="5" x2="5" y2="17"></line>
        <line x1="5" y1="5" x2="17" y2="17"></line>
      </svg>
    </button>
  </div>

  <!-- Links + bottom CTA -->
  <nav
    class="flex-1 flex flex-col px-10 pt-10 pb-10"
    aria-label="Mobile navigation"
  >
    <!-- Editorial left-aligned links with brand-red accent border -->
    <ul role="list" class="mobile-link-list flex flex-col gap-2 list-none m-0 p-0">
      {
        navLinks.map(({ label, href }, i) => (
          <li class="mobile-nav-item" style={`--i: ${i}`}>
            <a
              href={href}
              aria-current={isActive(href) ? "page" : undefined}
              class={`mobile-nav-link font-display font-bold text-ink no-underline${isActive(href) ? " mobile-nav-link-active" : ""}`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA anchored to bottom -->
    <div class="mobile-nav-item mt-auto" style="--i: 5">
      <a
        href="https://apps.apple.com/ca/app/unify-newcomer-support/id6754875762"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn inline-flex items-center gap-2 font-ui text-nav leading-nav tracking-cta font-medium bg-ink text-cream px-btn-x py-btn-y whitespace-nowrap no-underline"
      >
        Download Unify
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 7h10M8 3l4 4-4 4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
      <p class="mobile-cta-note">Free to download. No credit card required.</p>
    </div>
  </nav>
</div>

<style>
  .nav-pill {
    position: relative;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.72) 0%,
      rgba(255, 255, 255, 0.5) 100%
    );
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: var(--radius-pill);
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.8),
      inset 0 -1px 0 0 rgba(255, 255, 255, 0.2),
      0 8px 24px -8px rgba(23, 22, 22, 0.14),
      0 2px 6px -2px rgba(23, 22, 22, 0.08);
    transition:
      background 0.3s ease,
      box-shadow 0.3s ease;
  }

  /* Subtle top gloss highlight — simulates liquid refraction */
  .nav-pill::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.35) 0%,
      rgba(255, 255, 255, 0) 45%
    );
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  .nav-pill.is-scrolled {
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.85) 0%,
      rgba(255, 255, 255, 0.65) 100%
    );
    box-shadow:
      inset 0 1px 0 0 rgba(255, 255, 255, 0.9),
      inset 0 -1px 0 0 rgba(255, 255, 255, 0.25),
      0 14px 32px -10px rgba(23, 22, 22, 0.22),
      0 3px 10px -2px rgba(23, 22, 22, 0.1);
  }

  /* Desktop nav link — red underline grows from center on hover */
  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 100%;
    height: 2px;
    background: var(--color-brand-red);
    border-radius: 1px;
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }

  .nav-link:hover::after,
  .nav-link-active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .cta-btn {
    border-radius: var(--radius-cta);
  }

  /* Hamburger morph */
  .ham-line {
    display: block;
    width: 22px;
    height: 1.5px;
    background-color: var(--color-ink);
    border-radius: 2px;
    position: absolute;
    left: 50%;
    transform-origin: center;
    transition: transform 0.26s var(--ease-out), opacity 0.18s ease;
  }

  .ham-line-1 { transform: translateX(-50%) translateY(-7px); }
  .ham-line-2 { transform: translateX(-50%) translateY(0px); }
  .ham-line-3 { transform: translateX(-50%) translateY(7px); }

  .hamburger.is-open .ham-line-1 {
    transform: translateX(-50%) translateY(0) rotate(45deg);
  }
  .hamburger.is-open .ham-line-2 {
    opacity: 0;
    transform: translateX(-50%) scaleX(0);
  }
  .hamburger.is-open .ham-line-3 {
    transform: translateX(-50%) translateY(0) rotate(-45deg);
  }

  /* Mobile nav overlay */
  .mobile-nav {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-6px);
    transition:
      opacity 0.22s var(--ease-out),
      transform 0.22s var(--ease-out),
      visibility 0s linear 0.22s;
  }

  .mobile-nav.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
    transition:
      opacity 0.22s var(--ease-out),
      transform 0.22s var(--ease-out),
      visibility 0s linear 0s;
  }

  /* Editorial mobile links */
  .mobile-link-list {
    border-left: 3px solid var(--color-brand-red);
    padding-left: 1.5rem;
  }

  .mobile-nav-link {
    font-size: clamp(2rem, 6vw, 2.75rem);
    letter-spacing: var(--tracking-tight);
    line-height: 1.2;
    display: block;
    padding: 0.3rem 0;
    color: var(--color-text);
    transition: color 0.15s ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link-active {
    color: var(--color-brand-red);
  }

  .mobile-cta-note {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    color: var(--color-muted);
    opacity: 0.6;
    margin: 0.5rem 0 0;
  }

  /* Staggered reveals */
  .mobile-nav-item {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.28s ease, transform 0.28s var(--ease-out);
    transition-delay: calc(var(--i) * 50ms + 60ms);
  }

  .mobile-nav.is-open .mobile-nav-item {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initNavbar() {
    const pill = document.getElementById("nav-pill");
    const toggle = document.getElementById("nav-toggle") as HTMLButtonElement | null;
    const close = document.getElementById("nav-close");
    const menu = document.getElementById("mobile-nav");

    function updateScrollState() {
      if (!pill) return;
      pill.classList.toggle("is-scrolled", window.scrollY > 10);
    }

    // Remove any previous scroll listener before adding a new one
    window.removeEventListener("scroll", updateScrollState);
    window.addEventListener("scroll", updateScrollState, { passive: true });
    updateScrollState();

    function openMenu() {
      if (!menu || !toggle) return;
      menu.classList.add("is-open");
      toggle.classList.add("is-open");
      toggle.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      if (!menu || !toggle) return;
      menu.classList.remove("is-open");
      toggle.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    // Clean up old listeners by cloning elements
    if (toggle) {
      const newToggle = toggle.cloneNode(true) as HTMLButtonElement;
      toggle.parentNode?.replaceChild(newToggle, toggle);
      newToggle.addEventListener("click", openMenu);
    }
    if (close) {
      const newClose = close.cloneNode(true) as HTMLElement;
      close.parentNode?.replaceChild(newClose, close);
      newClose.addEventListener("click", closeMenu);
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu?.classList.contains("is-open")) closeMenu();
    });
  }

  // Reset body overflow and close menu before every navigation
  document.addEventListener("astro:before-preparation", () => {
    document.body.style.overflow = "";
    const menu = document.getElementById("mobile-nav");
    const toggle = document.getElementById("nav-toggle");
    if (menu) menu.classList.remove("is-open");
    if (toggle) {
      toggle.classList.remove("is-open");
      toggle.setAttribute("aria-expanded", "false");
    }
  });

  function updateActiveLinks() {
    const path = window.location.pathname;
    document.querySelectorAll<HTMLAnchorElement>(".nav-link, .mobile-nav-link").forEach((a) => {
      const href = a.getAttribute("href") ?? "";
      const isActive = href === "/" ? path === "/" : path.startsWith(href);
      a.classList.toggle("nav-link-active", a.classList.contains("nav-link") && isActive);
      a.classList.toggle("mobile-nav-link-active", a.classList.contains("mobile-nav-link") && isActive);
      if (isActive) {
        a.setAttribute("aria-current", "page");
      } else {
        a.removeAttribute("aria-current");
      }
    });
  }

  // Re-init on every page load (initial + soft navigations)
  document.addEventListener("astro:page-load", () => {
    initNavbar();
    updateActiveLinks();
  });
</script>
