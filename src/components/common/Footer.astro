---
const pages = [
  { label: "Home", href: "/", external: false },
  { label: "About", href: "/about", external: false },
  { label: "Blog", href: "/blog", external: false },
  { label: "Contact", href: "/contact", external: false },
  {
    label: "Privacy Policy",
    href: "https://www.notion.so/Unify-s-Privacy-Policy-2e15af89dddb80b0b37ee497e6d4e38c?source=copy_link",
    external: true,
  },
  {
    label: "Terms of Service",
    href: "https://www.notion.so/Unify-s-End-User-License-Agreement-Terms-of-Service-3185af89dddb80a68410fa8d65d615c7?source=copy_link",
    external: true,
  },
];

const social = [
  { label: "Instagram", href: "https://www.instagram.com/unifysocial.ca/" },
  {
    label: "Facebook",
    href: "https://www.facebook.com/p/Unify-Social-61570879043328/",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/unify-social/posts/?feedView=all",
  },
  { label: "Twitter", href: "https://x.com/unifysocialca" },
];
---

<footer class="bg-white border-t border-gray-100">
  <div class="mx-auto max-w-6xl px-6 desktop:px-10 pt-16 pb-10">
    <!-- Heading with brand-red left border -->
    <div class="footer-heading mb-12">
      <h2
        class="font-display font-bold text-footer-heading text-ink leading-tight"
      >
        Unify,<br />
        Your journey to Canada, <em>simplified.</em>
      </h2>
    </div>

    <!-- Two-column body: description left, links right -->
    <div class="flex flex-col tablet:flex-row gap-12 tablet:gap-16 mb-16">
      <!-- Left: brand description -->
      <div class="flex-1">
        <p class="font-display text-text text-base leading-relaxed max-w-2xl">
          Newcomers to Canada face a maze of disconnected resources, complex
          processes, and no clear starting point. Unify brings trusted
          information, step-by-step guidance, and real community into one place
          — so you never have to navigate the settlement journey alone.
        </p>
      </div>

      <!-- Right: Pages + Socials -->
      <div class="flex gap-12 tablet:gap-16 flex-shrink-0">
        <!-- Pages -->
        <div>
          <h3
            class="font-display font-semibold text-muted text-sm tracking-wide uppercase mb-5"
          >
            Pages
          </h3>
          <ul role="list" class="list-none m-0 p-0 flex flex-col gap-3">
            {
              pages.map(({ label, href, external }) => (
                <li>
                  <a
                    href={href}
                    class="font-display text-ink text-sm hover:text-brand hover:underline transition-colors duration-150"
                    target={external ? "_blank" : undefined}
                    rel={external ? "noopener noreferrer" : undefined}
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Socials -->
        <div>
          <h3
            class="font-display font-semibold text-muted text-sm tracking-wide uppercase mb-5"
          >
            Socials
          </h3>
          <ul role="list" class="list-none m-0 p-0 flex flex-col gap-3">
            {
              social.map(({ label, href }) => (
                <li>
                  <a
                    href={href}
                    class="font-display text-ink text-sm hover:text-brand hover:underline transition-colors duration-150"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-200 pt-6">
      <span class="font-display text-sm text-muted">© 2026 – Unify Social</span>
    </div>
  </div>
</footer>

<style>
  .footer-heading {
    border-left: 3px solid var(--color-brand);
    padding-left: 24px;
  }
</style>
