---
const navigate = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
];

const legal = [
  { label: "Privacy Policy", href: "/privacy" },
  { label: "Terms of Service", href: "/terms" },
];

const socials = [
  {
    label: "Instagram",
    href: "https://www.instagram.com/unifysocial.ca/",
    icon: "instagram",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/p/Unify-Social-61570879043328/",
    icon: "facebook",
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/unify-social/posts/?feedView=all",
    icon: "linkedin",
  },
  {
    label: "X (Twitter)",
    href: "https://x.com/unifysocialca",
    icon: "x",
  },
];
---

<footer class="unify-footer bg-white border-t border-gray-200">
  <div class="mx-auto max-w-6xl px-6 desktop:px-10 pt-20 pb-10">
    <!-- Top grid: brand + link columns -->
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="inline-block" aria-label="Unify Social home">
          <img
            src="/assets/logo/logo-with-name.avif"
            alt="Unify Social"
            class="h-14 w-auto"
            loading="lazy"
          />
        </a>

        <p class="footer-tagline font-display text-text text-base leading-relaxed mt-6 max-w-xs">
          An all-in-one mobile companion for newcomers in Canada. Built in
          Vancouver, with newcomers, for newcomers.
        </p>

        <ul role="list" class="footer-socials list-none m-0 p-0 mt-8 flex gap-3">
          {
            socials.map(({ label, href, icon }) => (
              <li>
                <a
                  href={href}
                  aria-label={label}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-social-btn"
                >
                  {icon === "instagram" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.6"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                    </svg>
                  )}
                  {icon === "facebook" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6A22 22 0 0 0 14.3 3.5c-2.4 0-4.05 1.45-4.05 4.1V9.9H7.5V13h2.75v8h3.25z" />
                    </svg>
                  )}
                  {icon === "linkedin" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM8.34 17.34H5.67v-8h2.67v8zM7 8.17a1.55 1.55 0 1 1 0-3.1 1.55 1.55 0 0 1 0 3.1zm11.34 9.17h-2.67v-4.2c0-1-.02-2.28-1.39-2.28-1.39 0-1.6 1.08-1.6 2.2v4.28h-2.67v-8h2.56v1.1h.04a2.8 2.8 0 0 1 2.52-1.38c2.7 0 3.2 1.77 3.2 4.08v4.2z" />
                    </svg>
                  )}
                  {icon === "x" && (
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M17.53 3h3.12l-6.82 7.79L22 21h-6.28l-4.92-6.43L5.18 21H2.06l7.3-8.34L2 3h6.44l4.45 5.88L17.53 3zm-1.1 16.13h1.73L7.65 4.77H5.8l10.63 14.36z" />
                    </svg>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Navigate -->
      <div class="footer-col">
        <h3 class="footer-col-title">Navigate</h3>
        <ul role="list" class="list-none m-0 p-0 flex flex-col gap-3">
          {
            navigate.map(({ label, href }) => (
              <li>
                <a href={href} class="footer-link">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer-col">
        <h3 class="footer-col-title">Legal</h3>
        <ul role="list" class="list-none m-0 p-0 flex flex-col gap-3">
          {
            legal.map(({ label, href }) => (
              <li>
                <a href={href} class="footer-link">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom mt-16 pt-6 border-t border-gray-200">
      <span class="font-display text-sm text-muted">© 2026 Unify Social</span>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 810px) {
    .footer-grid {
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr) minmax(0, 1fr);
      gap: 4rem;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
  }

  .footer-socials {
    display: flex;
    gap: 0.75rem;
  }

  .footer-col-title {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-muted);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer-link {
    font-family: var(--font-display);
    color: var(--color-ink);
    font-size: 0.95rem;
    transition: color 0.2s var(--ease-out);
  }

  .footer-link:hover {
    color: var(--color-brand);
  }

  .footer-social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 9999px;
    border: 1px solid rgba(0, 0, 0, 0.12);
    color: var(--color-ink);
    background: transparent;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      background-color 0.2s var(--ease-out),
      transform 0.2s var(--ease-out);
  }

  .footer-social-btn svg {
    width: 16px;
    height: 16px;
  }

  .footer-social-btn:hover {
    color: #ffffff;
    background-color: var(--color-brand);
    border-color: var(--color-brand);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
    justify-content: space-between;
  }

  @media (min-width: 810px) {
    .footer-bottom {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
